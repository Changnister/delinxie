/* Book a Talk form redesign */
/* --- Book a Talk Modern Styles --- */
.header-container {
  background: #fff;
  padding: 32px 0 0 0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: space-between;
  box-sizing: border-box;
}
@media (max-width: 700px) {
  .header-container {
    padding: 12px 14px;
  }
}
/* Book a Talk section now uses standard page background for consistency */
.contact-section {
  background: #fff;
  border-radius: 0;
  box-shadow: none;
}
.contact-section .container {
  max-width: 920px;
  margin: 0 auto;
  display: flex;
  gap: 40px;
  align-items: flex-start;
  justify-content: center;
  padding: 0 0;
  box-sizing: border-box;
}
.contact-form-wrap {
  flex: 1.8 1 0%;
  min-width: 340px;
  max-width: 560px;
  margin-right: 0;
  background: #fff;
  border-radius: 22px;
  box-shadow: none;
  border: 1.5px solid #ececf2;
  padding: 0;
  position: relative;
  z-index: 2;
}
.contact-form {
  gap: 22px;
  padding: 44px 44px 36px 44px;
  border-radius: 18px;
  box-shadow: none;
  border: none;
}
.form-header {
  margin-bottom: 28px;
  text-align: left;
}
.form-header h2 {
  font-size: 1.45rem;
  font-weight: 800;
  margin: 0 0 8px 0;
  letter-spacing: 0.01em;
  color: #0f1724;
}
.form-header .form-lede {
  color: #444;
  font-size: 1.08rem;
  margin: 0;
  line-height: 1.7;
}
.form-row {
  display: flex;
  flex-direction: column;
  gap: 7px;
}
.form-row-inline {
  display: flex;
  gap: 24px;
}
.form-row-inline .form-row {
  flex: 1 1 0;
}
.contact-form label {
  font-size: 1.04rem;
  font-weight: 500;
  color: #232946;
  margin-bottom: 2px;
  letter-spacing: 0.01em;
}
.contact-form .required {
  color: #d12c2c;
  font-size: 1em;
  margin-left: 2px;
}
.contact-form .optional {
  color: #888;
  font-size: 0.97em;
  margin-left: 2px;
}
.contact-form input,
.contact-form textarea {
  background: #fff;
  border: 1.5px solid #e0e0ea;
  border-radius: 9px;
  font-size: 1.04rem;
  color: #232946;
  transition:
    border 0.16s,
    box-shadow 0.16s;
  padding-left: 14px;
  padding-right: 14px;
}
.contact-form input:focus,
.contact-form textarea:focus {
  border-color: #0f3ba6;
  box-shadow: 0 2px 12px rgba(15, 59, 166, 0.1);
  background: #fff;
}
.form-btn {
  margin-top: 14px;
  padding: 15px 0;
  width: 100%;
  border-radius: 12px;
  font-size: 1.13rem;
  font-weight: 700;
  background: linear-gradient(90deg, #111 60%, #232946 100%);
  box-shadow: none;
  border: none;
  letter-spacing: 0.01em;
  color: #fff;
  transition:
    box-shadow 0.18s,
    background 0.18s;
}
.form-btn:hover,
.form-btn:focus {
  background: linear-gradient(90deg, #232946 60%, #111 100%);
  box-shadow: none;
}
.form-btn:disabled {
  opacity: 0.6;
  cursor: default;
}
.copy-card {
  background: #f7f8fa;
  border-radius: 18px;
  padding: 32px 28px 22px 28px;
  box-shadow: 0 4px 18px rgba(15, 23, 36, 0.06);
  border: 1.5px solid #ececf2;
  margin-top: 24px;
  min-width: 0;
}
.copy-card h3 {
  font-size: 1.13rem;
  font-weight: 700;
  margin: 0 0 14px 0;
  color: #232946;
}
.copy-card ul {
  margin: 0 0 14px 0;
  padding-left: 20px;
  color: #444;
  font-size: 1.01rem;
  line-height: 1.8;
}
.copy-card li {
  margin-bottom: 7px;
}
.copy-note {
  color: #888;
  font-size: 0.97rem;
  margin: 0;
}
@media (max-width: 900px) {
  .contact-section .container {
    gap: 18px;
    margin: 28px auto 36px auto;
    max-width: 98vw;
  }
  .contact-form-wrap {
    max-width: 100%;
    border-radius: 12px;
    box-shadow: none;
    padding: 0;
  }
  .contact-form {
    padding: 18px 8px 16px 8px;
    border-radius: 12px;
  }
  .form-row-inline {
    flex-direction: column;
    gap: 0;
  }
  .copy-card {
    padding: 18px 10px 12px 10px;
    border-radius: 12px;
    margin-top: 18px;
  }
  .contact-form {
    padding: 18px 8px 16px 8px;
    border-radius: 12px;
  }
  .form-row-inline {
    flex-direction: column;
    gap: 0;
  }
  .copy-card {
    padding: 18px 10px 12px 10px;
    border-radius: 10px;
  }
}
@media (max-width: 700px) {
  .contact-section {
    border-radius: 0 0 18px 18px;
    box-shadow: none;
  }
  .contact-section .container {
    flex-direction: column;
    width: calc(100% - 32px);
    margin: 0 16px 28px;
    max-width: 100vw;
    gap: 0;
  }
  .contact-form-wrap,
  .contact-copy {
    width: 100% !important;
    min-width: auto;
    max-width: 100%;
    border-radius: 10px;
    box-shadow: none;
    padding: 0;
  }
  .contact-form {
    padding: 10px 2px 10px 2px;
    border-radius: 8px;
  }
  .form-header h2 {
    font-size: 1.13rem;
  }
  .copy-card {
    margin-top: 14px;
    padding: 12px 4px 8px 4px;
    border-radius: 10px;
  }
  .contact-form {
    padding: 10px 2px 10px 2px;
    border-radius: 8px;
  }
  .form-header h2 {
    font-size: 1.1rem;
  }
  .copy-card {
    margin-top: 14px;
    padding: 12px 4px 8px 4px;
  }
}
/* WebCSS: site styles (hero, featured, articles, logos) */
:root {
  --content-max-w: 920px; /* central content column width used by hero and bentos */
  --content-gutter: 16px; /* inner horizontal padding to align sections */
}

/* Page-specific: make the bookings/inquiries form flush with page (no card) */
.form-page .contact-form-wrap {
  background: transparent;
  border: none;
  border-radius: 0;
  box-shadow: none;
  max-width: 580px;
  width: 100%;
}
.form-page .contact-form {
  background: transparent;
  padding: 32px 0 24px 0;
  border-radius: 0;
  gap: 26px;
}
.form-page .contact-section {
  background: transparent;
  padding-top: 48px;
  padding-bottom: 88px;
}
.form-page .form-btn {
  background: #0f1724;
  box-shadow: none;
  border-radius: 8px;
  padding: 13px 32px;
  width: auto;
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  transition: opacity 0.16s ease;
}
.form-page .form-btn:hover,
.form-page .form-btn:focus {
  background: #0f1724;
  box-shadow: none;
  opacity: 0.78;
}

/* Strong overrides to ensure no visible card/borders around the form */
.form-page .contact-form-wrap,
.form-page .contact-form,
.form-page .contact-section {
  border: none !important;
  box-shadow: none !important;
  background: transparent !important;
  border-radius: 0 !important;
}

/* Label & optional/required refinements for the bookings form */
.form-page .contact-form label {
  font-size: 0.86rem;
  font-weight: 600;
  color: #000;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.form-page .contact-form .required {
  color: #b94040;
  font-size: 0.9em;
}
.form-page .contact-form .optional {
  font-size: 0.82em;
  color: #9ca3af;
  text-transform: none;
  font-weight: 400;
  letter-spacing: 0;
}

/* ------------------------------------------------------------
   Final mobile polish pass
   ------------------------------------------------------------ */
@media screen and (max-width: 700px) {
  .header-container {
    padding: 12px 14px;
  }

  .header-item {
    font-size: 18px;
    padding-left: 0;
    letter-spacing: 1.1px;
  }

  .page-hero-title {
    padding-top: 44px;
    padding-bottom: 32px;
  }
  .page-hero-inner {
    text-align: center;
  }
  .page-hero-title .page-subtitle {
    margin-top: 14px;
    margin-bottom: 32px;
    font-size: 1.13rem;
    color: #444;
    line-height: 1.7;
  }

  .page-writing .page-hero-inner h1,
  .page-research .page-hero-inner h1,
  .page-creative .page-hero-inner h1,
  .page-media .page-hero-inner h1,
  .page-speaker .page-hero-inner h1,
  .page-about .page-hero-inner h1 {
    transform: none;
  }

  .home-hero {
    margin: 10px auto 8px;
    padding: 0;
    gap: 10px;
  }

  .home-hero .home-hero-inner {
    width: calc(100% - 32px);
    margin: 0 16px;
  }

  .hero-words .word {
    letter-spacing: 0.35px;
  }

  .home-hero-subtitle {
    margin: 12px 8px 14px;
    font-size: 0.98rem;
    line-height: 1.52;
  }

  .home-hero .hero-cta-row {
    width: 100%;
    gap: 8px;
  }

  .home-hero .hero-cta-row .portfolio-btn {
    min-height: 42px;
    padding: 0.42rem 0.9rem;
    border-radius: 10px;
  }

  .featured-heading {
    letter-spacing: 1.1px;
  }

  .filters-row {
    width: calc(100% - 32px);
    margin: 0 16px;
    padding: 10px;
    border-radius: 10px;
    row-gap: 8px;
  }

  .filter-col {
    margin-bottom: 8px;
    padding: 0;
  }

  .filter-col input,
  .filter-col select {
    min-height: 42px;
    border-radius: 10px;
  }

  #articleList,
  #homeFeaturedList,
  .list-container,
  .container {
    width: calc(100% - 32px);
    margin-left: 16px;
    margin-right: 16px;
  }

  .bento-grid {
    gap: 12px;
  }

  .bento-card {
    border-radius: 12px;
    box-shadow: 0 4px 14px rgba(15, 23, 36, 0.08);
  }

  .card-body {
    padding: 14px 14px 15px;
  }

  .card-title {
    font-size: 1rem;
    line-height: 1.34;
  }

  .site-footer {
    margin-top: 14px;
    padding: 12px 0;
  }

  .site-footer .site-footer-inner {
    width: calc(100% - 32px);
    margin: 0 16px;
    gap: 8px;
  }

  .site-footer .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 12px;
  }

  .site-footer .footer-right p {
    text-align: center;
    line-height: 1.45;
  }
}

/* Accessible default focus ring for keyboard navigation */
:focus-visible {
  outline: 3px solid #ffd700;
  outline-offset: 3px;
}

/* Reset button defaults for semantic hamburger button */
.hamburger {
  background: transparent;
  border: 0;
  padding: 0;
}

/* CTA button shared base */
.portfolio-btn.cv,
.portfolio-btn.speaking {
  border-radius: 9999px;
  transition:
    transform 0.12s ease,
    box-shadow 0.12s ease,
    background 0.12s ease;
}

/* Speaking / Book Me button */
.portfolio-btn.speaking {
  padding: 0.28rem 1.1rem;
  font-size: 0.98rem;
  min-width: 130px;
  background: #111;
  color: #fff;
  border: 2px solid #111;
  box-shadow: 0 8px 20px rgba(15, 23, 36, 0.07);
}
.portfolio-btn.speaking:hover {
  background: #111;
  color: #fff;
  transform: translateY(-2px);
}

/* CV button */
.portfolio-btn.cv {
  padding: 0.55rem 2rem;
  font-size: 0.92rem;
  min-width: 95px;
  background: #fff;
  color: #111;
  border: 2px solid #111;
  box-shadow: none;
}
.portfolio-btn.cv svg,
.portfolio-btn.speaking svg {
  width: 1.05em;
  height: 1.05em;
}
.portfolio-btn.cv:hover {
  background: #222;
  transform: translateY(-3px);
  box-shadow: 0 12px 26px rgba(15, 23, 36, 0.12);
}

/* Remove arrow from CV button */
.portfolio-btn.cv::after {
  content: none;
  display: none;
}

.portfolio-btn svg {
  display: inline-block;
  vertical-align: middle;
  width: 1.25em;
  height: 1.25em;
  margin-right: 0.5em;
}

/* Ensure hero CTA buttons have spacing */
.hero-cta-row .portfolio-btn {
  margin-right: 0.5em;
}
.hero-cta-row .portfolio-btn:last-child {
  margin-right: 0;
}

/* Add spacing between the two buttons in the hero section */
.hero-blurb .portfolio-btn {
  margin-right: 1.1em;
}
.hero-blurb .portfolio-btn:last-child {
  margin-right: 0;
}
/* Featured Works Heading Styles */
.featured-heading-section {
  text-align: center;
  background: #fff;
  padding: 18px 0 6px 0; /* tightened vertical spacing */
}
.featured-heading {
  font-size: 1.5em;
  font-weight: 900;
  letter-spacing: 2px;
  margin-bottom: 10px;
  margin-top: 0px;
  color: #000;
  position: relative;
  display: inline-block;
}
.featured-heading::after {
  content: "";
  display: block;
  margin: 12px auto 0 auto;
  width: 56px;
  height: 4px;
  border-radius: 2px;
  background: #ffd700;
  opacity: 0.95;
}

@media (max-width: 700px) {
  .featured-heading-section {
    padding: 24px 0 0 0;
  }
  .featured-heading {
    font-size: 1.2em;
    margin-bottom: 16px;
  }
  .featured-heading::after {
    width: 36px;
    height: 3px;
    margin: 8px auto 0 auto;
  }
}

/* Homepage featured works: separate, centered two-tile section that matches hero alignment */
.featured-works-container {
  /* slightly reduce width so bentos visually align with hero edges */
  max-width: var(--content-max-w);
  margin: 8px auto 24px auto; /* reduced top/bottom spacing */
  width: 100%;
  box-sizing: border-box;
  /* remove horizontal padding so we can express bento alignment via margins */
  padding: 0;
}

/* Use margins on the inner container so the bento grid aligns with the
   rest of the site's centered content column. This replaces the previous
   padding-based alignment for the "LATEST" section. */
.featured-works-container .container {
  width: 75%;
  margin-left: 11%;
  margin-right: 11%;
  box-sizing: border-box;
}

#homeFeaturedList {
  width: 100%;
  max-width: var(--content-max-w);
  margin: 0 auto;
  box-sizing: border-box;
  padding: 0; /* avoid extra inner spacing */
}

/* Scope container centering to the homepage only so other pages keep original behavior */
.home-page .container {
  max-width: var(--content-max-w);
  margin-left: auto;
  margin-right: auto;
  padding-left: var(--content-gutter);
  padding-right: var(--content-gutter);
  box-sizing: border-box;
}
.page-speaker .page-subtitle .page-contact {
  color: inherit;
  font-weight: inherit;
  border-bottom: none !important;
  padding-bottom: 0 !important;
  box-shadow: none !important;
  text-decoration: none !important;
}
.page-speaker .page-subtitle .page-contact:hover,
.page-speaker .page-subtitle .page-contact:focus {
  color: inherit;
  box-shadow: none !important;
  text-decoration: none !important;
  outline: none;
}

.bento-grid.featured-two {
  display: grid;
  grid-template-columns: repeat(
    2,
    minmax(360px, 1fr)
  ); /* slightly wider bentos */
  gap: 24px;
  align-items: stretch;
  justify-items: stretch;
  width: 100%;
}

/* On the homepage (desktop) hide the full article list and show the two-item featured grid.
   On small screens, show the full article list instead and hide the homepage featured two. */
.home-page #articleList {
  display: none;
}
.home-page #homeFeaturedList {
  display: block;
}

@media (max-width: 700px) {
  .home-page #homeFeaturedList {
    display: block; /* ensure featured items remain visible on small screens */
  }
  .bento-grid.featured-two {
    grid-template-columns: repeat(1, minmax(200px, 1fr));
    gap: 16px;
  }
}

/* Responsive tweaks to keep hero aligned with bento cards across breakpoints */
@media (max-width: 1200px) {
  .home-hero {
    gap: 64px;
  }
  .home-hero .home-hero-inner {
    width: 49%;
  }
  .bento-grid.featured-two {
    grid-template-columns: repeat(2, minmax(340px, 1fr));
  }
}
@media (max-width: 1000px) {
  .home-hero {
    gap: 48px;
  }
  .home-hero .home-hero-inner {
    width: 52%;
  }
  .bento-grid.featured-two {
    grid-template-columns: repeat(2, minmax(300px, 1fr));
  }
}
/* Article List Styles */
.article-link {
  text-decoration: none;
}
.article-img {
  width: 100%;
  height: 200px;
  border-radius: 8px;
  object-fit: cover;
  margin: 0px;
}
.article-title {
  margin: 8px 0 4px 0;
  color: black;
}
/* Text-only cover used for some speaking cards */
.text-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #ece6db;
  color: #111;
  font-family:
    Roboto,
    system-ui,
    -apple-system,
    "Segoe UI",
    "Helvetica Neue",
    Arial;
  padding: clamp(0.9rem, 2.2vw, 1.4rem);
  height: 180px; /* match .card-media default height */
  border-radius: 8px;
  box-sizing: border-box;
  width: 100%;
  line-height: 1.18;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  font-size: clamp(0.8rem, 1.6vw, 0.95rem);
  box-shadow: 0 4px 14px rgba(16, 24, 40, 0.04);
  padding-left: 1rem;
  padding-right: 1rem;
  max-width: 64ch;
  margin: 0 auto;
  word-wrap: break-word;
  hyphens: auto;
  transition:
    box-shadow 0.18s ease,
    transform 0.18s ease;
}

/* Ensure text cover follows same responsive heights as images */
@media screen and (max-width: 1000px) {
  .text-cover {
    height: 170px; /* match .card-media at this breakpoint */
  }
}

@media screen and (max-width: 700px) {
  .text-cover {
    height: 150px; /* match .card-media on small screens */
    font-size: clamp(0.95rem, 2.6vw, 1.05rem);
  }
}
.article-meta {
  margin: 0 0 4px 0;
}
.article-journal {
  margin: 0 0 4px 0;
  color: #2d2564;
  font-weight: 600;
  letter-spacing: 0.5px;
}
/* Spoken At Section Styles */

.spoken-section {
  text-align: center;
  margin: 0;
  background: #111;
  padding: 32px 0 40px 0;
}
.spoken-section h3 {
  font-size: 1.5em;
  font-weight: 900;
  letter-spacing: 2px;
  margin-bottom: 18px;
  margin-top: 0px;
  color: #fff;
  position: relative;
  display: inline-block;
}
.spoken-section h3::after {
  content: "";
  display: block;
  margin: 12px auto 0 auto;
  width: 56px;
  height: 4px;
  border-radius: 2px;
  background: linear-gradient(90deg, #ffd700 0%, #ffb300 100%);
  opacity: 0.95;
}
.spoken-logos-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 40px 60px;
  align-items: center;
}
.spoken-logos-row .logo-img {
  max-height: 48px;
  filter: grayscale(1) brightness(0) invert(1); /* force white */
  transition:
    filter 0.2s,
    opacity 0.2s,
    transform 0.18s;
  padding: 10px 18px;
  border-radius: 10px;
}
/* Hover effect for spoken logos */
.spoken-logos-row .logo-img:hover {
  filter: grayscale(1) brightness(0) invert(1) drop-shadow(0 0 12px #ffd700);
  transform: scale(1.04);
  opacity: 0.95;
  background: rgba(255, 215, 0, 0.03);
}
/* Mobile optimization for spoken-section */

/* Sticky footer: ensure footer stays at bottom on all viewports */
/* Make the main content area grow to fill available space */
.home-container {
  flex: 1 0 auto;
}
/* Prevent footer from shrinking and ensure it sits at the bottom */
.site-footer,
.mobile-footer-rights {
  flex-shrink: 0;
  margin-top: 0;
}
@media (max-width: 700px) {
  .spoken-section {
    padding: 36px 0 28px 0;
  }
  .spoken-section h3 {
    font-size: 1.2em;
    margin-bottom: 16px;
  }
  .spoken-section h3::after {
    width: 36px;
    height: 3px;
    margin: 8px auto 0 auto;
  }
  .spoken-logos-row {
    gap: 14px 6vw;
    padding: 0 2vw;
  }
  .spoken-logos-row .logo-img {
    max-width: 38vw;
    max-height: 28px;
    padding: 6px 4vw;
    margin-bottom: 6px;
    border-radius: 8px;
    object-fit: contain;
    filter: brightness(0) saturate(100%);
  }
}
/* Lightbox styling for media feature previews */
.lightbox-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.72);
  z-index: 10000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.18s ease;
}
.lightbox-overlay.open {
  opacity: 1;
  pointer-events: auto;
}
.lightbox-content {
  /* Allow the image to render at its natural dimensions. If it's larger
     than the viewport, make the content scrollable so the user can pan. */
  max-width: 100vw;
  max-height: 100vh;
  display: block;
  padding: 24px;
  box-sizing: border-box;
  overflow: auto;
}
.lightbox-content img {
  /* Show the image at its intrinsic size. If larger than viewport the
     surrounding .lightbox-content will provide scrollbars. */
  display: block;
  width: auto;
  height: auto;
  max-width: none;
  max-height: none;
  border-radius: 4px;
  box-shadow: 0 18px 60px rgba(2, 6, 23, 0.6);
}
.lightbox-close {
  position: absolute;
  top: 18px;
  right: 18px;
  font-size: 28px;
  line-height: 1;
  color: #fff;
  background: transparent;
  border: none;
  cursor: pointer;
}
/* Logos Section Styles */
.logos-section {
  text-align: center;
  margin: 0;
  background: #ffffff; /* match page background */
  padding: 32px 0 40px 0;
}
.logos-section h3 {
  font-size: 1.5em;
  font-weight: 900;
  letter-spacing: 2px;
  margin-bottom: 18px;
  margin-top: 0px;
  color: #000; /* dark heading on white background */
  position: relative;
  display: inline-block;
}
.logos-section h3::after {
  content: "";
  display: block;
  margin: 12px auto 0 auto;
  width: 56px;
  height: 4px;
  border-radius: 2px;
  background: linear-gradient(90deg, #ffd700 0%, #ffb300 100%);
  opacity: 0.95;
}
/* Constrain the logos and speaking sections to the site's content width
   so they align with the hero and featured works sections. */
.spoken-section .spoken-logos-row,
.logos-section .logos-scroll-container {
  max-width: var(--content-max-w);
  margin: 0 auto; /* center within page */
  padding-left: var(--content-gutter);
  padding-right: var(--content-gutter);
  box-sizing: border-box;
}
.logos-scroll-container {
  position: relative;
  overflow: visible; /* allow inner container to handle clipping */
  display: block;
  padding: 6px 0; /* tighter vertical spacing */
}

/* Ensure the carousel's left/right edges align with the featured bento grid */
.logos-scroll-container .container {
  max-width: var(--content-max-w);
  margin-left: auto;
  margin-right: auto;
  padding-left: calc(var(--content-gutter) + 70px);
  padding-right: calc(var(--content-gutter) + 70px);
  box-sizing: border-box;
  display: block; /* override .container flex behavior for the carousel */
  width: 100%;
}

.logos-scroll {
  width: 100%;
  padding-left: 0;
  padding-right: 0;
  display: flex;
  gap: 28px;
  align-items: center;
  flex-wrap: nowrap;
  will-change: transform;
  --marquee-duration: 40s;
  animation: marquee-linear var(--marquee-duration) linear infinite;
  animation-play-state: paused;
}
.logos-scroll:hover {
  animation-play-state: paused;
}
.logos-scroll .logo-img {
  flex: 0 0 auto;
  width: clamp(
    90px,
    12vw,
    140px
  ); /* responsive logo width that aligns with content gutters */
  height: auto;
  max-height: 56px;
  object-fit: contain;
  filter: grayscale(1) brightness(0); /* force fully black logos */
  opacity: 0.68;
  transition:
    opacity 0.18s ease,
    filter 0.18s ease;
}
.logos-scroll .logo-img:hover,
.logos-scroll .logo-img:focus-visible {
  opacity: 1;
}

/* Page-scoped marquee copies so homepage and speaker marquees can be
   styled independently while keeping current appearance. */
.home-page .logos-scroll .logo-img {
  flex: 0 0 auto;
  width: clamp(90px, 12vw, 140px);
  height: auto;
  max-height: 56px;
  object-fit: contain;
  filter: grayscale(1) brightness(0);
}
.logos-scroll .logo-img:focus {
  outline: 3px solid #ffd700;
  outline-offset: 4px;
}
@keyframes marquee-back {
  0% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(var(--translate));
  }
  100% {
    transform: translateX(0);
  }
}
@keyframes marquee-linear {
  0% {
    transform: translateX(0);
  }
  100% {
    /* Prefer an explicit --translate variable (set by JS). If not present,
       fall back to calculating the negative of --one-seq. This is
       more robust across browsers that may not reliably allow multiplication
       of CSS variables in calc(). */
    transform: translateX(var(--translate, calc(var(--one-seq, 0px) * -1)));
  }
}
@media (prefers-reduced-motion: no-preference) {
  .logos-scroll {
    animation-play-state: running;
  }
}

@media (max-width: 700px) {
  .logos-scroll .logo-img {
    width: 90px;
    max-height: 40px;
  }
}

/* Speaking logos override when used inside the marquee container
   Keep sizes similar to the previous spoken-logos-row behaviour but
   scoped to when the row is a marquee (.logos-scroll.spoken-logos-row) */
.logos-scroll.spoken-logos-row .logo-img {
  max-height: 42px;
  width: auto;
  padding: 8px 14px;
  border-radius: 10px;
  filter: grayscale(1) brightness(0);
}
@media (max-width: 700px) {
  .logos-scroll.spoken-logos-row .logo-img {
    max-width: 38vw;
    max-height: 24px;
    padding: 5px 3.5vw;
    border-radius: 8px;
  }
}

/* Writing + Speaker pages: shared marquee container sizing */
.page-writing .logos-section,
.page-speaker .logos-section {
  margin-left: 0;
  margin-right: 0;
  padding-top: 18px;
  padding-bottom: 8px;
  background: transparent;
}
.page-writing .logos-scroll-container,
.page-speaker .logos-scroll-container {
  max-width: none;
  margin: 0;
  padding-left: 0;
  padding-right: 0;
  overflow: hidden;
}
.page-writing .logos-scroll-container .container,
.page-speaker .logos-scroll-container .container {
  max-width: none;
  width: 75%;
  margin-left: 11%;
  margin-right: 11%;
  padding-left: 0;
  padding-right: 0;
  box-sizing: border-box;
  display: block;
  overflow: hidden;
  position: relative;
}
.page-writing .logos-scroll,
.page-speaker .logos-scroll {
  width: 100%;
  padding-left: 0;
  gap: 22px;
}

.page-writing .filters-row,
.page-speaker .filters-row {
  margin-top: 4px;
}

.page-writing .logos-scroll-container .container::before,
.page-writing .logos-scroll-container .container::after,
.page-speaker .logos-scroll-container .container::before,
.page-speaker .logos-scroll-container .container::after {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  width: 44px;
  z-index: 2;
  pointer-events: none;
}

.page-writing .logos-scroll-container .container::before,
.page-speaker .logos-scroll-container .container::before {
  left: 0;
  background: linear-gradient(to right, #ffffff 0%, rgba(255, 255, 255, 0));
}

.page-writing .logos-scroll-container .container::after,
.page-speaker .logos-scroll-container .container::after {
  right: 0;
  background: linear-gradient(to left, #ffffff 0%, rgba(255, 255, 255, 0));
}

@media (max-width: 700px) {
  .page-writing .logos-section,
  .page-speaker .logos-section {
    display: none;
  }

  .page-writing .logos-scroll-container .container,
  .page-speaker .logos-scroll-container .container {
    width: calc(100% - 32px);
    margin: 0 16px;
  }

  .page-writing .filters-row,
  .page-speaker .filters-row {
    margin-top: 10px;
  }
}

/* Homepage: ensure the bylines marquee is clipped to the same centered
   content area used by the bentos so logos cannot overflow past margins. */
.home-page .logos-scroll-container {
  max-width: none;
  margin: 0;
  padding-left: 0;
  padding-right: 0;
}
.home-page .logos-scroll-container .container {
  /* Copy marquee container sizing used by the featured/other pages so the
     homepage bylines marquee aligns with the featured bento edges. */
  max-width: var(--content-max-w);
  margin-left: auto;
  margin-right: auto;
  padding-left: calc(var(--content-gutter) + 70px);
  padding-right: calc(var(--content-gutter) + 70px);
  box-sizing: border-box;
  display: block;
  width: 100%;
  overflow: hidden; /* clip animated track to this centered area */
}

/* Base styles for html and body */
html,
body {
  font-family: "Roboto", sans-serif;
  font-weight: 400;
  height: 100%;
  margin: 0px;
  padding: 0px;
  width: 100%;
}

/* Body background and font */
body {
  font-family: "Roboto", sans-serif;
  margin: 0;
  padding: 0;
  background-color: white;
}

/* Flex container for article cards */
.container {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 20px 20px;
  line-height: 24px;
  color: black;
  text-align: left;
  letter-spacing: 1px;
  margin-left: 11%;
  margin-right: 11%;
  margin-bottom: 16px;
  width: 75%;
}

/* Select/input styling scoped to filter controls */
.filters-row select,
.filters-row input[type="text"] {
  display: flex;
  width: 100%;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin: 0;
  border: none;
  font-size: 14px;
  font-family: "Roboto", sans-serif;
}

/* Remove outline on input focus */
.filters-row input[type="text"]:focus {
  outline: none;
}

.filters-row input[type="text"]:focus-visible,
.filters-row select:focus-visible,
.page-subtitle .page-contact:focus-visible,
.page-speaker .page-subtitle .page-contact:focus-visible,
.media-item a:focus-visible,
.hamburger:focus-visible {
  outline: 3px solid #ffd700;
  outline-offset: 3px;
}

/* Remove underline from links */
a:link {
  text-decoration: none;
}

/* Responsive styles for mobile */
@media screen and (max-width: 768px) {
  .column {
    width: 100%; /* Make columns full width on mobile */
  }
}

/* Filters row and columns */
.filters-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-left: 11%;
  margin-right: 11%;
  width: 75%;
  padding: 18px 0; /* vertical spacing only, no background/border */
  gap: 12px;
  font-family: "Roboto", sans-serif;
  box-sizing: border-box;
  align-items: center;
}

.filters-row.has-chip-ui .filter-col {
  width: calc(50% - 8px);
}
.filter-col {
  width: calc(33.333% - 12px);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  font-family: "Roboto", sans-serif;
  box-sizing: border-box;
  padding: 0 6px; /* small padding so inputs don't touch edges */
}
.filter-col input,
.filter-col select {
  width: 100%;
  box-sizing: border-box;
  font-size: 15px;
  font-family: "Roboto", sans-serif;
  border: 1px solid #d1d1e0;
  border-radius: 6px;
  padding: 10px 18px; /* more right padding so native down-arrow has breathing room */
  margin: 0;
  background: #fff;
  color: #222;
  transition: border 0.2s;
}

.filter-chip-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 7px;
  width: 75%;
  margin: 2px 11% 14px;
  padding: 0;
}

.filter-chip {
  border: 1px solid rgba(45, 37, 100, 0.2);
  background: #fff;
  color: #2d2564;
  border-radius: 999px;
  padding: 6px 11px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  cursor: pointer;
}

.filter-chip:hover,
.filter-chip:focus-visible {
  border-color: #2d2564;
  background: rgba(45, 37, 100, 0.06);
  outline: none;
}

.filter-chip.is-active {
  background: #2d2564;
  color: #fff;
  border-color: #2d2564;
}

@media (prefers-reduced-motion: no-preference) {
  .filter-chip {
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease,
      opacity 0.2s ease,
      transform 0.2s ease;
  }
}

@media (max-width: 700px) {
  .filters-row.has-chip-ui .filter-col {
    width: 100%;
  }

  .filter-chip-row {
    width: calc(100% - 32px);
    margin: 0 16px 10px;
    gap: 6px;
  }

  .filter-chip {
    font-size: 11px;
    padding: 6px 10px;
  }
}
.filter-col input:focus,
.filter-col select:focus {
  border: 1.5px solid #2d2564;
  outline: none;
  background: #f0f0fa;
}

/* Booking styles removed — not used in this site build. */

@media (max-width: 700px) {
  .featured-works-note {
    font-size: 0.89rem;
    padding: 0 4vw;
    line-height: 1.5;
  }
}

/* Responsive filter row and column adjustments */
@media screen and (max-width: 700px) {
  .filters-row {
    flex-direction: column;
    /* Use fixed 16px side gutters on mobile for pixel-consistent alignment */
    width: calc(100% - 32px);
    margin: 0 16px;
    padding: 14px 0 8px 0;
    box-sizing: border-box;
  }
  .filter-col {
    width: 100%;
    margin-bottom: 12px;
    /* remove internal padding on mobile so controls align flush with container edges */
    padding: 0;
  }
  .filter-col select {
    padding: 6px 8px;
    font-size: 14px;
  }
  .filters-row input[type="text"] {
    padding: 6px 12px;
    font-size: 14px;
    margin-top: 0;
  }

  /* Ensure filter controls fill their column on mobile and align with content width */
  .filters-row .filter-col select,
  .filters-row .filter-col input[type="text"],
  .filters-row input[type="text"],
  .filters-row select {
    width: 100%;
    margin: 0;
    box-sizing: border-box;
  }

  /* remove any global left/right margins/widths that could push controls inward */
  .filters-row .filter-col input[type="text"],
  .filters-row .filter-col select {
    margin-left: 0 !important;
    margin-right: 0 !important;
    width: 100% !important;
    padding-left: 16px; /* match the 16px gutter */
    padding-right: 16px; /* match the 16px gutter */
  }

  /* Ensure article/list containers use the same content column width so bento cards
     align horizontally with the filters on mobile */
  .container,
  .list-container {
    /* Use the same fixed gutters as filters for perfect alignment */
    width: calc(100% - 32px);
    margin: 0 16px;
    box-sizing: border-box;
    gap: 18px 18px;
  }

  /* If the bento grid has its own spacing, make sure it fills the container */
  .bento-grid {
    width: 100%;
    box-sizing: border-box;
    padding-left: 0;
    padding-right: 0;
    margin-left: 0;
    margin-right: 0;
  }
}

/* Page container layout */
.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh; /* ensure footer can be pushed to bottom on short pages */
}

/* Make the main content area grow to fill available space so footer sits at bottom */
main.content,
.page-content {
  flex: 1 0 auto;
}

/* Post photo placeholder styles (used by individual post pages) */
.post-photo-wrap {
  width: 75%;
  margin-left: 11%;
  margin-right: 11%;
  margin-top: 18px;
  margin-bottom: 18px;
  box-sizing: border-box;
}
.post-photo {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 8px;
  object-fit: cover;
  box-shadow: 0 8px 20px rgba(15, 23, 36, 0.06);
  border: 1px solid rgba(15, 20, 40, 0.03);
}

@media (max-width: 700px) {
  .post-photo-wrap {
    width: calc(100% - 32px);
    margin-left: 16px;
    margin-right: 16px;
  }
}

/* Three-photo gallery: aesthetic layout with one large image + two stacked */
.post-gallery {
  width: 75%;
  margin-left: 11%;
  margin-right: 11%;
  margin-top: 18px;
  margin-bottom: 18px;
  display: grid;
  grid-template-columns: 2fr 1fr;
  grid-template-rows: 1fr 1fr;
  grid-template-areas: "main side1" "main side2";
  gap: 16px;
  align-items: stretch;
  box-sizing: border-box;
}
.post-gallery .photo-main {
  grid-area: main;
  height: 100%;
}
.post-gallery .photo-side1 {
  grid-area: side1;
  height: 100%;
}
.post-gallery .photo-side2 {
  grid-area: side2;
  height: 100%;
}
.post-gallery .post-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: 8px;
  cursor: zoom-in;
  transition: transform 0.18s ease;
}
.post-gallery .post-photo:hover {
  transform: translateY(-4px);
}

@media (max-width: 900px) {
  .post-gallery {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    grid-template-areas: "main main" "side1 side2";
  }
}

@media (max-width: 700px) {
  .post-gallery {
    display: block; /* stack images vertically on small screens */
    width: calc(100% - 32px);
    margin-left: 16px;
    margin-right: 16px;
  }
  .post-gallery .post-photo {
    margin-bottom: 12px;
    height: auto;
    width: 100%;
    cursor: zoom-in;
  }
}

/* Post/article typography and layout for food blog readability */
.post {
  width: 100%;
}
.post .post-body {
  max-width: 720px;
  margin-left: 11%;
  margin-right: 11%;
  font-size: 18px;
  line-height: 1.78;
  color: #222;
  margin-top: 18px;
  margin-bottom: 28px;
}
.post h1,
.post h2,
.post h3 {
  color: #111;
  margin-top: 1.1em;
  margin-bottom: 0.6em;
}
.post h2 {
  font-size: 1.35rem;
}
.post p {
  margin-bottom: 1em;
}

/* Figure and caption styling for photos */
figure.post-figure {
  margin: 0 0 1rem 0;
}
figure.post-figure .post-photo {
  border-radius: 8px;
}
figcaption.post-caption {
  font-size: 0.95rem;
  color: #6a6f78;
  margin-top: 6px;
}

/* Small meta-block for recipe/posts (centered under title) */
.post-meta {
  max-width: 720px;
  margin-left: 11%;
  margin-right: 11%;
  color: #6a6f78;
  font-size: 0.95rem;
  margin-bottom: 12px;
}

/* Ensure gallery images use consistent object-position for food photos */
.post-gallery .post-photo {
  object-position: center center;
}

@media (max-width: 700px) {
  .post .post-body {
    font-size: 16px;
    line-height: 1.6;
    margin-left: 16px;
    margin-right: 16px;
  }
  .post-meta {
    margin-left: 16px;
    margin-right: 16px;
  }
}

/* Vitae PDF container */
.vitae-container {
  padding: 50px 20px;
  text-align: center;
  width: 100%;
}
.vitae-object {
  width: 80%;
  height: 800px;
  border: none;
}
.vitae-unavailable {
  width: 80%;
  margin: 0 auto;
  color: #4c5561;
  font-size: 1rem;
  line-height: 1.6;
  text-align: center;
}

/* Header styles */
.header-container {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: auto;
  justify-content: space-between;
  margin: 36px;
}
.header-container a {
  text-decoration: none;
  color: black;
}

/* Reorder header elements so social icons appear to the left of the nav on wide screens */
.header-container .header-item {
  order: 0;
}
.header-container .nav {
  order: 1;
  flex: 1 1 auto; /* allow nav to expand so it can be centered */
  justify-content: center; /* center nav items */
}
.header-container .socialmedia {
  order: 2;
  margin-left: 0;
  margin-right: 28px; /* extra spacing on the right */
}
.header-container .hamburger {
  order: 3;
  margin-left: 0;
}
.header-item {
  font-size: 22px;
  color: black;
  text-align: left;
  font-weight: 800;
  letter-spacing: 1.4px;
  padding-left: 18px;
}

/* Make header sticky with a persistent bottom rule */
.header-container {
  position: sticky;
  top: 0;
  margin: 0; /* remove upper spacing to tighten header */
  background: #ffffff;
  z-index: 2000;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  padding-top: 18px; /* increased vertical padding (top) */
  padding-bottom: 18px; /* increased vertical padding (bottom) */
}

/* Page title block shown under the header (one-line subtitle) */
.page-hero-title {
  background: #ffffff;
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  padding-top: 14px;
  padding-bottom: 8px;
}
/* Align the title block to the article/content column (75% width with 11% margins)
   so the title lines up with the page content */
.page-hero-inner {
  width: 75%;
  margin-left: 11%;
  font-size: clamp(24px, 3.2vw + 12px, 40px);
  font-weight: 700;
}
.page-hero-inner h1 {
  margin: 0 0 12px 0;
  /* Option C modified per request: not bold, reduced size, capitalized */
  font-size: clamp(28px, 5vw, 52px);
  font-weight: 600; /* not bold */
  line-height: 1.06;
  letter-spacing: 1.2px;
  color: #0f1724;
  text-transform: capitalize; /* Title Case (capitalized words) */
  max-width: 880px;
}
.page-subtitle {
  margin: 0;
  color: #6a6f78;
  font-size: 15px;
  font-weight: 400;
  letter-spacing: 0.4px;
  padding-top: 8px;
  max-width: 820px;
  border-top: none; /* removed thin divider */
}

/* Clean, subtle styling for contact link inside page subtitles */
.page-subtitle .page-contact {
  color: #2d2564; /* site-standard indigo link color */
  font-weight: 600;
  text-decoration: none;
  border-bottom: 1px dotted rgba(45, 37, 100, 0.12);
  padding-bottom: 2px;
  transition:
    color 0.12s ease,
    box-shadow 0.12s ease;
}
.page-subtitle .page-contact:hover,
.page-subtitle .page-contact:focus {
  color: #0f1724; /* darken on hover/focus for contrast */
  text-decoration: none;
  box-shadow: inset 0 -2px 0 rgba(45, 37, 100, 0.1);
  outline: none;
}

@media (max-width: 700px) {
  .page-hero-title {
    padding: 18px 16px;
  }
  .page-hero-inner {
    width: calc(100% - 32px);
    margin: 0 16px;
  }
  .page-hero-inner h1 {
    font-size: clamp(26px, 7.6vw, 40px);
  }
  .page-subtitle {
    font-size: 13px;
  }
}

/* ─── Homepage active indicator ─────────────────────────────────────────────
   The brand name (PETER ZHANG) is the home link, so highlight it on the
   homepage with the same gold accent used across the site.
*/
.home-page .header-item a {
  border-bottom: 2px solid #ffd700;
  padding-bottom: 2px;
}

/* Navigation bar styles */
.nav-item {
  font-size: 13px;
  color: #0f1724;
  text-align: center;
  font-weight: 700;
  letter-spacing: 1.1px;
  margin-right: 0; /* removed fixed right margin to allow even distribution */
  padding: 0; /* remove internal padding so link fills the item */
  text-transform: uppercase;
  transition:
    background-color 0.18s,
    color 0.12s;
}
.nav-item a {
  display: block; /* make the anchor fill the nav-item for a larger click target */
  padding: 9px 13px; /* larger, comfortable tap/click area */
  color: inherit;
  text-decoration: none;
  border-bottom: 2px solid transparent;
}
.nav-item a.is-active,
.nav-item a[aria-current="page"] {
  border-bottom-color: #ffd700;
}
.nav-item:hover {
  background-color: rgba(45, 37, 100, 0.04);
  border-radius: 6px;
}
.nav {
  display: flex;
  flex-direction: row;
  justify-content: center; /* center nav items in available space */
  flex: 1 1 auto; /* allow nav to grow and center within header */
  max-width: 900px;
  gap: 16px; /* slightly wider spacing between nav items */
}

/* Social media icon styles */
.socialmedia {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px; /* slightly more breathing room between icons */
  margin-left: 6px; /* nudge the social icons left, closer to nav */
}
.media-item img {
  height: 24px;
  width: auto;
  display: block;
  transition:
    transform 0.12s ease,
    filter 0.12s ease,
    opacity 0.12s ease;
}
/* Header-specific: slightly larger icons for improved tap targets and visibility */
.header-container .socialmedia .media-item img {
  height: 30px; /* slightly larger for better visibility */
}
.media-item {
  margin-right: 0; /* rely on flex gap instead of per-item margins */
  padding-top: 2px;
}
.media-item:last-child {
  margin-right: 0;
  padding-right: 0;
}
.media-item img:hover,
.media-item img:focus {
  transform: scale(1.1);
  filter: drop-shadow(0 4px 12px rgba(45, 37, 100, 0.12));
  opacity: 0.95;
}
.media-item a:focus {
  outline: 3px solid #ffd700;
  outline-offset: 4px;
  border-radius: 6px;
}

/* Hide social icons inside the header for tablet and smaller screens (<=1024px) */
@media (max-width: 1024px) {
  .header-container .socialmedia {
    display: none !important;
    visibility: hidden;
    height: 0;
    overflow: hidden;
  }
}

/* Main content container */
.home-container {
  display: flex;
  flex-direction: row;
  justify-content: center;
  width: auto;
}

/* Home left item styles */
.homeitemleft {
  font-size: 32px;
  color: black;
  text-align: left;
  font-weight: bold;
  letter-spacing: 1px;
  margin-bottom: 0px;
  padding-top: 35%;
  padding-left: 20%;
}

/* Blurb styles */
.blurb-item {
  font-size: 16px;
  line-height: 28px;
  color: black;
  text-align: left;
  letter-spacing: 1px;
  margin-left: 20%;
  margin-right: 35%;
}
/* Project/half-column styles removed — not referenced by pages */

/* Contributions / row blocks removed — not referenced by active pages */

/* Footer styles */
.footer-container {
  display: flex;
  width: 100%;
  flex-direction: row;
  justify-content: center;
  margin-top: 2%;
  flex: 1;
}
.footer-item {
  font-size: 14px;
  color: black;
  text-align: center;
  letter-spacing: 2px;
  margin-top: auto;
}

/* New semantic site footer styling (matches reference two-column dark footer) */
.site-footer {
  background: #111;
  color: #ffffff;
  font-family: "Roboto", sans-serif;
  padding: 12px 0; /* slightly tighter desktop padding */
  margin-top: auto; /* ensure footer sits at bottom when page content is short */
}
.site-footer .site-footer-inner {
  width: 75%;
  margin-left: 11%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px; /* balanced gap */
  box-sizing: border-box;
}
.site-footer .footer-left {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.site-footer .footer-logo a {
  display: none; /* hide the name/logo text per request */
}
.site-footer .footer-nav {
  color: white;
  font-size: 15px;
}
.site-footer .footer-nav a {
  color: white;
  text-decoration: none;
  margin-right: 12px; /* keep spacing but no bullet characters in HTML */
  font-size: 14px; /* match nav items */
  font-weight: 900; /* bold like nav */
  letter-spacing: 1px; /* same tracking as nav */
  text-transform: uppercase; /* match nav case */
  padding: 8px 6px; /* compact padding */
}
.site-footer .footer-nav a:hover {
  color: #ffd700; /* gold accent on hover */
}
.site-footer .footer-contact {
  display: none; /* hide the email/contact line per request */
}
.site-footer .footer-right p {
  color: #9ea3a8;
  margin: 0;
  text-align: right;
  font-size: 14px; /* match nav font-size for better alignment */
  line-height: 1.2;
  letter-spacing: 1px; /* subtle tracking to harmonize with nav */
}
.site-footer .footer-right .footer-name {
  color: #ffffff;
  font-weight: 400; /* do not bold the name */
  margin-left: 6px;
}

@media (max-width: 700px) {
  /* Keep footer on a single row on small screens, reduce spacing and font sizes so it fits */
  .site-footer {
    padding: 6px 0; /* compact vertical padding */
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .site-footer .site-footer-inner {
    width: calc(100% - 24px);
    margin: 0 12px;
    flex-direction: row; /* keep in one line */
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    box-sizing: border-box;
  }

  .site-footer .footer-left,
  .site-footer .footer-right {
    width: auto;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  /* Compact horizontal nav */
  .site-footer .footer-nav {
    display: flex;
    flex-direction: row;
    gap: 8px;
    padding: 0;
    align-items: center;
  }

  .site-footer .footer-nav a {
    display: inline-block;
    padding: 4px 6px;
    font-size: 12px;
    color: #d6d6d6;
    white-space: nowrap;
  }

  .site-footer .footer-nav a:hover {
    color: #ffd700;
  }

  .site-footer .footer-right p {
    text-align: right;
    margin: 0;
    color: #bfc3c6;
    font-size: 12px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 48%;
  }

  .site-footer .footer-right .footer-name {
    font-weight: 400 !important;
    margin-left: 6px;
  }
}

/* Mobile-only simple rights line: show only on small screens and keep single-line */
@media (max-width: 700px) {
  .site-footer .site-footer-inner {
    display: none;
  }
  .mobile-footer-rights {
    display: block;
    text-align: center;
    color: #bfc3c6;
    /* match site footer font but allow dynamic shrinking so it fits on one line */
    font-family: inherit;
    font-weight: 400;
    font-size: clamp(12px, 3.5vw, 14px); /* scale between 12 and 14px */
    padding: 6px 12px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    background: #111; /* match footer background */
  }
}

@media (min-width: 701px) {
  .mobile-footer-rights {
    display: none;
  }
}

/* Ensure mobile/tablet footer uses the same font/format as desktop and stays single-line
   Show the compact single-line rights element for screens up to 1024px (phones and tablets).
   This overrides the min-width:701px rule above for devices between 701px and 1024px. */
@media (max-width: 1024px) {
  /* Hide the desktop footer completely on smaller screens so there is
     only one compact footer line (the mobile rights bar). */
  .site-footer {
    display: none;
  }

  /* Compact single-line rights element for phones and tablets.
     Keep it in normal flow so it appears at the bottom of the page. */
  .mobile-footer-rights {
    display: block;
    text-align: center;
    color: #9ea3a8;
    font-family: "Roboto", sans-serif;
    font-weight: 400;
    letter-spacing: 1px;
    line-height: 1;
    font-size: clamp(11px, 1.6vw, 14px);
    padding: 10px 12px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    background: #111;
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
    margin: 0;
    position: relative;
    left: auto;
    transform: none;
  }

  .mobile-footer-rights .footer-name {
    color: #ffffff;
    font-weight: 700;
    margin-left: 6px;
  }
}

/* (No body padding added) */

/* Mobile adjustments: tighten space after featured works, hide header social icons */
@media (max-width: 700px) {
  /* Reduce gap between last featured/work grid and footer */
  .featured-works-container {
    margin-bottom: 8px; /* smaller gap on mobile */
    padding-bottom: 0;
  }
  /* Ensure home featured list doesn't add extra bottom padding */
  #homeFeaturedList {
    padding-bottom: 8px;
  }
}

/* List container for main content */
.list-container {
  display: flex;
  width: 100%;
  flex-direction: column;
  justify-content: center;
}
.list-image > img {
  width: 100vw;
  max-width: 100vw;
  height: 450px;
  object-fit: cover;
  display: block;
  border-radius: 0;
  margin: 0;
}
.list-introduction {
  font-size: 24px;
  color: black;
  text-align: left;
  font-weight: 900;
  letter-spacing: 2px;
  margin-left: 11%;
  margin-top: 2%;
  margin-bottom: 30px;
}
/* .list-items removed — not used in current pages */

/* Hide hamburger by default on wide screens; mobile helpers cleaned */
.hamburger {
  display: none;
}

/* Push hamburger to far right so header items remain left-aligned on wide screens */
.header-container .hamburger {
  margin-left: auto;
}

/* Responsive styles for screens below 1024px */
@media (max-width: 1024px) {
  .header-container {
    display: flex;
    flex-direction: row;
    align-items: center;
    position: relative;
    width: auto;
    justify-content: space-between;
    padding-bottom: 18px;
    padding-top: 18px;
  }
  .header-item {
    font-size: 16px;
    color: black;
    text-align: left;
    font-weight: 900;
    letter-spacing: 3px;
    padding-left: 15px;
    float: left;
  }
  .nav {
    position: absolute;
    left: -100%;
    top: calc(100% + 8px);
    flex-direction: column;
    background-color: #fff;
    width: 100%;
    border-radius: 8px;
    text-align: center;
    transition: 0.3s;
    box-shadow: 0 10px 27px rgba(0, 0, 0, 0.05);
    z-index: 2500;
  }
  .nav-item {
    margin-right: 0;
  }
  .nav-item:hover {
    margin-right: 0;
  }
  .nav.active {
    left: 0;
  }
  /* When the mobile menu is opened, make the nav span the full width
     of the header (remove earlier desktop max-width) so each item can
     occupy the full horizontal space for easy tapping/clicking. */
  .header-container .nav.active {
    position: absolute;
    left: 0;
    right: 0; /* stretch to both edges of the header container */
    width: 100%;
    max-width: none; /* override desktop max-width constraint */
    box-sizing: border-box;
    padding-left: 0;
    padding-right: 0;
  }
  .header-container .nav.active .nav-item {
    width: 100%;
    display: block;
    text-align: center; /* center labels on mobile responsive interfaces */
    border-bottom: none; /* remove divider lines between items on mobile */
    box-sizing: border-box;
  }
  .header-container .nav.active .nav-item a {
    padding: 12px 16px; /* mobile-friendly tappable area */
    display: block;
    width: 100%;
    box-sizing: border-box;
  }
  .vitae-object {
    width: 100%;
    height: 600px;
  }
  .vitae-container {
    margin-top: 5%;
    display: flex;
    flex-direction: row;
    justify-content: center;
    width: auto;
  }
  .vitaeresponsive {
    height: 900px;
    width: 90%;
  }
  .hamburger {
    display: block;
    cursor: pointer;
    margin-right: 15px;
  }
  .hamburger.active .bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger.active .bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .hamburger.active .bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
  .bar {
    display: block;
    width: 25px;
    height: 3px;
    margin: 5px auto;
    background-color: #101010;
  }
  .list-image {
    margin: 0;
    height: 200px;
  }
  .list-image > img {
    object-fit: cover;
    height: 100%;
  }
  .project-introduction {
    margin-top: 24px;
  }
  .row {
    display: flex;
    flex-direction: column;
    padding-top: 0;
  }
  .mobilerow {
    display: flex;
    flex-direction: column;
    padding-top: 20%;
  }
  .column {
    float: left;
    width: 100%;
    text-align: left;
    padding-bottom: 10px;
    padding-top: 10px;
    padding-right: 0px;
    padding-left: 0px;
    margin: 0px;
  }
  .column-head {
    font-size: 18px;
    color: black;
    text-align: center;
    font-weight: bold;
    letter-spacing: 1px;
    margin-bottom: 0px;
    margin-top: 35px;
  }
  .column-item {
    font-size: 14px;
    line-height: 28px;
    color: black;
    text-align: center;
    letter-spacing: 1px;
    margin-top: 10px;
    margin-left: 5%;
    margin-right: 5%;
  }
  .columnicon-item img {
    height: 50px;
    width: 50px;
  }
  .columnicon-item {
    padding-top: 35px;
  }
  .halfcolumnprojecttext {
    width: 75%;
  }
  .home-container {
    margin: 0;
    width: auto;
  }
  .mobile-image {
    margin-bottom: 16px;
    display: block;
  }
  .mobile-image > img {
    width: 100%;
  }
  .body-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-left: 0px;
  }
  .list-image {
    margin: 0;
  }
  .list-introduction {
    margin-top: 20px;
    padding-top: 25px;
  }
  .introduction-item {
    font-size: 24px;
    width: 100%;
    text-align: center;
    margin-bottom: 20px;
    margin-top: 20px;
  }
  .footer-item {
    font-size: 10px;
    padding-top: 25px;
  }
}

/* Hero blurb section for homepage */
.hero-blurb {
  margin: 24px 0 0 0;
  padding: 30px 8% 30px 8%; /* Larger, even padding */
  border-radius: 14px; /* Slightly more rounded */
  max-width: 900px; /* Prevents it from being too wide on large screens */
  margin-left: auto;
  margin-right: auto;
}
.hero-blurb h1 {
  font-size: 2.2rem; /* Slightly larger headline */
  margin-bottom: 28px; /* More space below heading */
  color: #232946; /* Professional, dark blue */
  font-weight: 800; /* Stronger weight */
  letter-spacing: 1px;
  line-height: 1.15;
}

/* Home hero: two-column layout with stacked words on the left and a square image on the right */
.home-hero {
  position: relative;
  max-width: var(--content-max-w);
  margin: 18px auto; /* reduced vertical spacing */
  display: flex;
  align-items: center; /* vertically center image with the title text */
  justify-content: space-between; /* keep left/right columns spaced */
  gap: 80px; /* increased separation between hero text and image */
  padding: 12px var(--content-gutter); /* slightly reduced padding */
  color: #0f1724;
  background: #ffffff;
}
.home-hero .home-hero-inner {
  position: relative;
  width: 46%; /* slightly narrower so image has more room and edges align with bentos */
  margin: 0;
  z-index: 2;
  text-align: left;
}

.hero-cv-wrap {
  display: flex;
  align-items: center;
}
.home-hero > .hero-cv-wrap {
  /* ensure it sits to the right column when home-hero is flex */
  align-self: center;
}

@media (max-width: 700px) {
  .hero-cv-wrap {
    margin-top: 8px;
  }
  .home-hero > .hero-cv-wrap {
    align-self: center;
  }
}
.hero-words {
  display: flex;
  flex-direction: column;
  gap: 8px; /* tighter stack for headline words */
  margin-bottom: 10px; /* space before subtitle/button */
}
.home-hero .home-hero-inner {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.hero-words .word {
  font-size: clamp(24px, 5.8vw, 56px);
  font-weight: 600;
  line-height: 1.04; /* balanced line-height */
  color: #0f1724;
  letter-spacing: 0.6px;
  text-transform: uppercase;
  margin: 0;
}
.home-hero .hero-cta-row {
  margin-top: 14px;
  display: flex;
  gap: 6px;
  align-items: center;
}

/* Hero-specific CTA sizing: compact pills with tighter icon/text spacing */
.home-hero .hero-cta-row .portfolio-btn {
  padding: 0.36rem 0.92rem;
  font-size: 0.95rem;
  min-height: 40px;
  display: inline-flex;
  align-items: center;
  gap: 0.4em; /* reduce icon / text gap */
  box-sizing: border-box;
  border-radius: 12px; /* slightly less rounded for hero CTAs */
}
.home-hero .hero-cta-row .portfolio-btn.speaking {
  min-width: 110px;
  background: #111;
  color: #fff;
  border: 2px solid #111;
  box-shadow: 0 8px 20px rgba(15, 23, 36, 0.07);
  border-radius: 12px;
}
.home-hero .hero-cta-row .portfolio-btn.cv {
  min-width: 82px;
  padding: 0.32rem 0.76rem;
  background: #fff;
  color: #111;
  border: 2px solid #111;
  box-shadow: none;
  border-radius: 12px;
  opacity: 0.92;
}
.home-hero .hero-cta-row .portfolio-btn svg {
  width: 16px;
  height: 16px;
  margin-right: 0.4em;
}

/* Subtitle styling inside the hero */
.home-hero-subtitle {
  margin: 8px 0 12px 0; /* tightened spacing */
  color: #444;
  font-size: 1rem;
  line-height: 1.5;
  max-width: 60ch;
}
.home-hero-media {
  width: clamp(140px, 20vw, 300px);
  height: clamp(140px, 20vw, 300px);
  background-position: center center;
  background-size: cover;
  background-repeat: no-repeat;
  border-radius: 8px;
  margin: 0; /* symmetric gutters handled by the centered container */
  box-shadow: 0 8px 22px rgba(15, 23, 36, 0.08); /* subtle elevation */
  border: 1px solid rgba(15, 23, 36, 0.04);
  margin-left: 0; /* remove fixed left offset so media aligns with content gutters */
  transform: none;
}

@media (max-width: 900px) {
  .home-hero .home-hero-inner {
    width: 62%;
  }
  .home-hero-media {
    width: 40vw;
    height: 40vw;
    transform: none;
  }
}

@media (max-width: 700px) {
  .home-hero {
    flex-direction: column-reverse;
    align-items: center;
    padding: 8px 8px;
  }
  .home-hero .home-hero-inner {
    width: calc(100% - 32px);
    margin: 0 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center; /* center text and buttons */
  }
  .hero-words {
    align-items: center;
    gap: 10px; /* a bit more vertical space between the stacked words */
  }
  .home-hero-media {
    width: calc(100% - 32px);
    /* Use a stable aspect ratio on small screens so height is never zero.
       Previous calculation used 100% of the parent (which can be undefined),
       resulting in zero height on some viewports. */
    height: auto;
    aspect-ratio: 1 / 1;
    margin: 0 16px 16px 16px;
    transform: none;
  }
  .hero-words .word {
    font-size: clamp(18px, 9.6vw, 26px);
  }
  .home-hero-subtitle {
    margin: 16px 12px 18px 12px; /* more vertical breathing room under the stacked words */
    text-align: center;
  }
  .home-hero .hero-cta-row {
    margin-top: 14px;
    justify-content: center; /* center CTAs on phone */
    gap: 10px;
  }

  /* Ensure featured works and bentos remain centered on phones */
  .featured-works-container {
    padding: 0 16px;
    box-sizing: border-box;
  }
  .bento-grid.featured-two {
    grid-template-columns: repeat(1, minmax(240px, 1fr));
    justify-items: center;
    gap: 14px;
  }
}

.hero-blurb p {
  font-size: 1.15rem;
  color: #333;
  margin: 0 auto 28px auto; /* More space below blurb */
  line-height: 1.7;
  font-weight: 400;
  text-align: center;
  max-width: 800px;
}
.hero-blurb em {
  font-style: italic;
  color: black;
}
.hero-blurb-btn {
  display: inline-block;
  margin-top: 0;
  margin-bottom: 10px; /* Add vertical space below each button */
  margin-right: 28px; /* Slightly more horizontal gap */
  padding: 8px 28px;
  min-width: 90px;
  background: black;
  color: #fff;
  font-size: 1.07rem;
  font-weight: 600;
  border-radius: 7px;
  text-decoration: none;
  transition:
    background 0.2s,
    box-shadow 0.2s,
    transform 0.18s;
  box-shadow: 0 2px 10px rgba(35, 41, 70, 0.13);
  vertical-align: middle;
}
.hero-blurb-btn:last-child {
  margin-right: 0;
}
.hero-blurb-btn:hover {
  background: black;
  color: #fff;
  box-shadow: 0 4px 16px rgba(35, 41, 70, 0.12);
}

/* Responsive adjustments for hero blurb */
@media (max-width: 700px) {
  .hero-blurb {
    padding: 24px 12% 24px 10%;
  }
  .hero-blurb h1 {
    font-size: 1.4rem;
  }
  .hero-blurb p {
    font-size: 1rem;
    text-align: left;
  }
  .hero-blurb-btn {
    width: 100%;
    font-size: 1rem;
    padding: 12px 0;
    box-sizing: border-box;
    margin-right: 0;
    min-width: unset;
  }
  .hero-blurb-btn:not(:last-child) {
    margin-bottom: 10px;
  }
}

/* Bento grid and card styles (for publications / media / scholarly lists) */

.bento-grid {
  display: grid;
  grid-template-columns: repeat(
    3,
    minmax(260px, 1fr)
  ); /* three columns with sensible min width */
  gap: 22px; /* slightly tighter, consistent spacing */
  align-items: stretch; /* make cards stretch to equal height within a row */
  grid-auto-rows: 1fr; /* ensure each grid row distributes space evenly */
  margin: 0;
  padding: 0;
  width: 100%;
}

.bento-card {
  background: #fff;
  border-radius: 10px;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition:
    transform 0.18s ease,
    box-shadow 0.18s ease,
    border-color 0.12s ease;
  height: 100%; /* fill the grid row so cards in a row match heights */
  border: 1px solid rgba(15, 20, 40, 0.03); /* subtle border to define edges */
}

.bento-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1);
}

.card-media {
  width: 100%;
  height: 180px; /* balanced image height for title/content ratio */
  object-fit: cover;
  background: #f6f6f6;
  display: block;
  /* Preserve layout containment without delaying near-fold image rendering. */
  contain: layout style paint;
  will-change: transform;
}

.card-body {
  padding: 18px 16px; /* balanced padding for compactness */
  display: flex;
  flex-direction: column;
  justify-content: flex-end; /* push title/date/collaborators toward bottom of the bento */
  gap: 10px;
  flex: 1 1 auto;
  box-sizing: border-box;
  overflow: visible;
  position: relative;
}

.card-content {
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1 1 auto; /* allow the text block to grow and fill empty vertical space */
  justify-content: space-between; /* spread title and journal vertically to use space */
}

/* Flexible spacer inserted into cards to consume available vertical space
   and keep meta blocks pinned to the bottom (used on writing and speaker pages). */
.card-spacer {
  flex: 1 1 auto;
  min-height: 6px; /* ensure a tiny visual gap if present */
}

.card-journal {
  color: #0f3ba6; /* refined rich blue for emphasis */
  font-weight: 900; /* very bold to emphasize outlet */
  font-size: 15px; /* larger for prominence */
  margin-top: 0px;
  margin-bottom: 8px;
  letter-spacing: 0.6px;
  text-transform: none; /* show publication outlet names in normal case */
}

@media screen and (max-width: 1000px) {
  .bento-grid {
    grid-template-columns: repeat(2, minmax(220px, 1fr));
    gap: 18px;
  }
  .card-media {
    height: 170px;
  }
}

@media screen and (max-width: 700px) {
  /* reduce visual weight on small screens */
  .bento-grid {
    grid-template-columns: repeat(1, minmax(200px, 1fr));
    gap: 14px;
  }
  .card-media {
    height: 150px;
  }
  .card-title {
    -webkit-line-clamp: 2;
    line-clamp: 2;
    font-size: 16px;
  }
  .card-journal {
    color: #0b2a8a;
    font-size: 13px;
    font-weight: 800;
    text-transform: none;
    letter-spacing: 0.3px;
    margin-bottom: 6px;
  }
}

.card-meta {
  color: #666;
  font-size: 13px;
}

.card-title {
  display: -webkit-box;
  -webkit-line-clamp: 3; /* keep titles concise and consistent */
  line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 18px; /* balanced presence */
  font-weight: 700;
  line-height: 1.28;
  margin: 0 0 6px 0;
  color: #111;
}

/* Use Roboto in the bento cards explicitly */
.bento-card {
  font-family: "Roboto", sans-serif;
}

/* Make the whole card clickable: link fills the card */
.bento-card a.card-link {
  display: flex;
  flex-direction: column;
  height: 100%;
  color: inherit;
  text-decoration: none;
}

/* For bentos without a real URL (renderer uses "#"), show default cursor
   instead of the pointer so they don't appear clickable on hover. */
.bento-card a.card-link[href="#"],
.bento-card a.card-link[href=""] {
  cursor: default;
}

/* Read more visual (span) - subtle with arrow */
.read-more {
  color: #6b6b6b;
  font-size: 0.78rem;
  font-weight: 400; /* not bold */
  align-self: flex-end;
  margin-top: 8px;
  opacity: 0.85;
}

.read-more:hover {
  text-decoration: underline;
  opacity: 1;
}

.read-more::after {
  content: "\2192"; /* right arrow */
  margin-left: 6px;
  font-weight: 400;
}

/* Normalize spacing of elements inside the card content so
   titles, journal, date, and authors have consistent margins */
.card-content > * {
  margin: 0; /* spacing controlled by .card-content gap */
}

/* Make sure media doesn't shrink on narrow layouts and keep the focal point centered */
.bento-card .card-media {
  flex-shrink: 0;
  object-position: center center;
}

/* Slightly tighten journal/date/author spacing for readability */
.card-date,
.card-authors {
  margin: 0;
  color: #6b6b6b;
}

/* Position the read-more in the bottom-right of the card body */
.read-more {
  display: none !important;
}

/* Media pages: keep images slightly smaller so text has room */
.page-media .card-media {
  height: 200px;
  object-position: center center;
}

/* Meta block that sits at the bottom of the card body */
.card-meta-block {
  margin-top: auto; /* pushes the meta block to the bottom */
  display: flex;
  flex-direction: column;
  gap: 6px;
}

/* Highlight the date so it's easier to scan */
.card-meta-block .card-date {
  color: #2d2564; /* same accent as journal */
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.2px;
}

.card-meta-block .card-authors {
  color: #6b6b6b;
  font-size: 13px;
  font-style: italic;
}

/* When a specific no-italic marker is present, force normal style for co-authors/collaborators */
.card-authors.no-italic {
  font-style: normal;
}

/* Ensure article list aligns with filters (same width & margins) */
#articleList {
  display: block;
  width: 75%;
  margin-left: 11%;
  margin-right: 11%;
  padding: 0;
  box-sizing: border-box;
}

/* Page-specific tuning: make Creative bentos match Publications sizing and alignment */
.page-creative #articleList {
  width: 75%;
  margin-left: 11%;
  margin-right: 11%;
}
.page-creative .filters-row {
  width: 75%;
  margin-left: 11%;
  margin-right: 11%;
}
.page-creative .card-media {
  height: 210px; /* match publications image height */
  object-position: center center;
}

/* Keep Creative page hero/title spacing aligned with global page rhythm */
.page-creative #articleList {
  padding-bottom: 64px; /* add breathing room at bottom instead */
}

/* Prevent creative list from being vertically centered (caused by global centering) */
.page-creative .list-container {
  justify-content: flex-start;
}

@media screen and (max-width: 700px) {
  /* ensure article list and grid use the same fixed gutters */
  #articleList {
    width: calc(100% - 32px);
    margin: 0 16px;
    box-sizing: border-box;
  }
  /* Creative has page-specific desktop width rules with higher specificity,
     so we must override them explicitly on mobile to match other pages. */
  .page-creative #articleList,
  .page-creative .filters-row {
    width: calc(100% - 32px);
    margin-left: 16px;
    margin-right: 16px;
    box-sizing: border-box;
  }
  .bento-grid {
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 14px;
    width: 100%;
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }
  .bento-card {
    height: auto;
    min-height: 320px;
  }
  .card-media {
    height: 160px;
  }
  .card-title {
    -webkit-line-clamp: 3;
    line-clamp: 3;
    font-size: 16px;
  }

  /* Add bottom padding so the last bento card has breathing room above the footer */
  /* Keep the total visible gap between last bento and footer consistent when footer top padding changes.
      Target total gap = 32px (articleList padding-bottom + footer top padding).
      With footer top padding now 4px, articleList bottom padding should be 28px. */
  #articleList {
    padding-bottom: 28px;
  }
}

.card-meta {
  font-size: 13px;
  color: #666;
}

.card-tags {
  margin-top: 6px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}

.tag {
  background: transparent;
  color: #2d2564;
  padding: 0;
  font-size: 13px;
  border-radius: 2px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  display: inline-flex;
  align-items: center;
}

.tag::before {
  content: "";
  display: inline-block;
  width: 8px;
  height: 8px;
  background: #ffd700; /* gold marker */
  border-radius: 2px;
  margin-right: 6px;
}

/* Ensure tag marker shows on speaker page (enable yellow dot) */
.page-speaker .tag::before {
  display: inline-block;
}

.page-creative .card-content {
  gap: 8px; /* match publications/media spacing between title and journal */
  min-height: 88px; /* increase so journal is pushed down like other pages */
  display: flex;
  flex-direction: column;
  flex: 1 1 auto;
  justify-content: space-between;
}
.page-creative .card-journal {
  margin-bottom: 8px;
}
/* Smaller course name line shown under the course-code/institution */
.card-course {
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
  line-height: 1.2;
}

/* Business Planning specific cover tuning to avoid cropping important areas */
.bp-media {
  /* focus further right and slightly higher so both "Business Planning" and
     the "Introduction to the Business Model Canvas" component remain visible */
  object-position: 40% 14%;
  height: 230px; /* taller to reveal more of the cover artwork */
}
@media screen and (max-width: 1000px) {
  .bp-media {
    height: 200px;
    object-position: 42% 18%;
  }
}
@media screen and (max-width: 700px) {
  .bp-media {
    height: 170px;
    object-position: 50% 22%;
  }
}
/* bottom-left tag container inside cards */
.card-tags-inline {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-left: auto; /* ensure tags sit at the far right */
}

/* On the speaker page, place tags under the title and left-aligned */
.page-speaker .card-tags-inline {
  margin-left: 0;
}

/* layout the date and inline tags on the same row */
.card-meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  width: 100%;
}

/* Speaker page: make card content fill available space more naturally.
   Reduce artificial spacers and use flex alignment so cards don't leave
   large empty gaps while preserving `card-media` heights. */
.page-speaker .card-course {
  display: block; /* keep course visible when present */
  margin-bottom: 4px; /* tighten gap to the date below */
}

/* Prefer flex distribution over large invisible spacers. Use a small
   spacer only when necessary so cards remain visually consistent. */
.page-speaker .card-course::after {
  content: "";
  display: block;
  height: 6px; /* reduced spacer to bring date closer to course */
}

.page-speaker .card-content:not(:has(.card-course)) .card-journal::after {
  content: "";
  display: block;
  height: 6px; /* reduced fallback spacer when course is missing */
}

@media screen and (max-width: 700px) {
  .page-speaker .card-course::after,
  .page-speaker .card-content:not(:has(.card-course)) .card-journal::after {
    height: 4px; /* reduced on small screens */
  }
}

/* Use flex-start on speaker card bodies so content stacks naturally and
   fills the card area; allow `.card-content` to grow when needed. */
.page-speaker .card-body {
  justify-content: flex-start; /* stack content from the top */
}

.page-speaker .card-content {
  justify-content: flex-start; /* avoid forcing large gaps between items */
  gap: 8px;
}

/* Make journal, course and date use consistent spacing via the card body's gap */
.page-speaker .card-body {
  gap: 6px; /* equal vertical spacing between children */
}

.page-speaker .card-spacer {
  min-height: 4px; /* smaller top spacer so bottom group sits closer */
}

.page-speaker .card-journal,
.page-speaker .card-course,
.page-speaker .card-meta-block {
  margin: 0; /* remove individual margins so gap controls spacing */
}

/* Tighten vertical spacing between journal, course, and date on speaker cards */
.page-speaker .card-journal {
  margin-bottom: 4px; /* bring journal closer to course/date */
  font-size: 14px;
}

.page-speaker .card-meta-block {
  gap: 6px; /* smaller gap between date and collaborators */
}

.page-speaker .card-meta-row {
  gap: 8px; /* shrink horizontal gap between date and inline items */
}

.page-speaker .card-authors {
  margin-top: 2px;
  color: #666;
  font-size: 13px;
}

.card-meta-row .card-date {
  flex: 0 0 auto; /* keep date compact on the left */
}
.card-meta-row .card-tags-inline {
  flex: 0 0 auto; /* keep tags compact on the right */
}

.card-tags-inline .tag {
  background: transparent;
  padding: 0;
  font-size: 13px;
  font-weight: 800;
  text-transform: uppercase;
  color: #2d2564;
  letter-spacing: 0.6px;
}

.page-creative .card-meta-block {
  padding-bottom: 8px; /* keep a small buffer but avoid large extra space */
}

/* Creative-specific bento formatting tweaks */
.page-creative .bento-grid {
  gap: 22px; /* match global bento grid spacing */
}
.page-creative .bento-card {
  border-radius: 10px; /* match global card radius */
}
.page-creative .card-body {
  padding: 18px 16px; /* match global card-body padding */
}
.page-creative .card-title {
  font-size: 18px; /* match global title size */
  margin-bottom: 6px;
}
.page-creative .card-journal {
  font-size: 15px; /* match global journal size */
  color: #0f3ba6;
  font-weight: 900;
  margin-bottom: 8px;
}
.page-creative .card-meta-block {
  gap: 6px; /* slightly more room between date, tags, authors */
  align-items: flex-start;
}
.page-creative .card-date {
  font-weight: 700;
  color: #2d2564;
  font-size: 13px;
}
.page-creative .card-authors {
  color: #6b6b6b;
  font-size: 13px;
  font-style: italic;
}
.page-creative .card-tags {
  margin-top: 2px;
}

@media screen and (max-width: 1000px) {
  .page-creative .card-body {
    padding: 16px 14px;
  }
  .page-creative .card-title {
    font-size: 17px;
  }
}
/* Mobile: make Creative bentos feel like Publications/Media on small viewports */
@media screen and (max-width: 700px) {
  .page-creative .card-body {
    padding: 14px 14px 16px; /* match shared mobile card padding */
  }
  .page-creative .card-media {
    height: 160px; /* match shared mobile card image height */
  }
  .page-creative .card-title {
    -webkit-line-clamp: 3;
    line-clamp: 3;
    font-size: 16px;
    margin-bottom: 6px;
  }
  .page-creative .card-content {
    min-height: 0;
    gap: 8px;
    justify-content: flex-start;
  }
  .page-creative .card-journal {
    font-size: 13px;
    margin-bottom: 6px;
  }
  .page-creative .card-meta-block {
    gap: 6px;
    padding-bottom: 6px;
  }
  .card-meta-row {
    gap: 10px;
  }
}
/* CTA was removed: decorative CTA icon deleted to simplify cards */

@media (max-width: 520px) {
  .bento-card {
    min-height: 260px;
  }
  .card-media {
    height: 120px;
  }

  .page-writing .logos-scroll-container,
  .page-speaker .logos-scroll-container {
    overflow: visible;
  }

  .page-writing .logos-scroll-container .container,
  .page-speaker .logos-scroll-container .container {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .page-writing .logos-scroll-container .container::-webkit-scrollbar,
  .page-speaker .logos-scroll-container .container::-webkit-scrollbar {
    display: none;
  }

  .page-writing .logos-scroll,
  .page-speaker .logos-scroll {
    width: max-content;
    padding-right: 14px;
    scroll-snap-type: x proximity;
  }

  .page-writing .logos-scroll .logo-img,
  .page-speaker .logos-scroll .logo-img {
    scroll-snap-align: start;
  }

  .page-writing .logos-scroll-container .container::before,
  .page-writing .logos-scroll-container .container::after,
  .page-speaker .logos-scroll-container .container::before,
  .page-speaker .logos-scroll-container .container::after {
    display: none;
  }
}

/* Footer alignment to match articleList width */
.footer-container {
  padding: 28px 0;
}
.footer-container .footer-item {
  width: 75%;
  margin-left: 11%;
  margin-right: 11%;
}

/* The main content wrapper used across pages. Ensure it expands to fill available space. */
.page-container > .home-container {
  flex: 1 1 auto;
}

/* Hide social media icons on responsive/narrow views (Nest Hub Max, tablets, etc.) */
@media (max-width: 1200px) {
  .socialmedia {
    display: none !important;
    visibility: hidden;
    height: 0;
    overflow: hidden;
  }
}

/* Also hide at <=1300px to cover devices like Nest Hub Max (1280px width) */
@media (max-width: 1300px) {
  .header-container .socialmedia {
    display: none !important;
    visibility: hidden !important;
    height: 0 !important;
    overflow: hidden !important;
  }
}

/* Ensure featured works container aligns with the hero content column.
   Override generic .container margins so the homepage sections share the
   same centered content width and left/right gutters. */
.featured-works-container .container,
#homeFeaturedList {
  margin-left: auto !important;
  margin-right: auto !important;
  padding-left: var(--content-gutter) !important;
  padding-right: var(--content-gutter) !important;
  width: 100%;
  max-width: var(--content-max-w);
  box-sizing: border-box;
}

/* Ensure hero inner content uses the same inner gutters so left edges align */
.home-hero .home-hero-inner {
  padding-left: var(--content-gutter);
  padding-right: var(--content-gutter);
  box-sizing: border-box;
}

/* Speaker page: refine bento spacing and enforce uniform card sizes
   - Keep cover height unchanged (image and text covers remain 180/170/150)
   - Tighten grid gaps and ensure cards in the speaker page are visually consistent
*/
.page-speaker .bento-grid {
  gap: 18px; /* slightly tighter spacing for speaker list */
  grid-auto-rows: 1fr; /* keep rows balanced so cards match height */
}

.page-speaker .bento-card {
  min-height: 400px; /* enforce a uniform minimum card height on desktop */
  height: 100%;
  border-radius: 10px;
}

.page-speaker .card-body {
  padding: 18px 18px; /* slightly more horizontal breathing room */
}

/* Explicitly preserve cover heights used elsewhere so we don't change cover size */
.page-speaker .card-media,
.page-speaker .text-cover {
  height: 180px;
}

@media screen and (max-width: 1000px) {
  .page-speaker .bento-card {
    min-height: 360px;
  }
  .page-speaker .card-media,
  .page-speaker .text-cover {
    height: 170px;
  }
}

@media screen and (max-width: 700px) {
  .page-speaker .bento-card {
    min-height: 300px;
  }
  .page-speaker .card-media,
  .page-speaker .text-cover {
    height: 150px;
  }
}

/* ─── Vitae download row ─────────────────────────────────────────────────────
   Prominent download button above the PDF embed.
*/
.vitae-download-row {
  display: flex;
  justify-content: flex-start;
  padding: 24px 40px 0;
}

@media screen and (max-width: 700px) {
  .vitae-download-row {
    padding: 16px 20px 0;
  }
}

/* ─── Article count label ────────────────────────────────────────────────────
   Small muted count that appears next to the page subtitle.
*/
.article-count {
  font-size: 0.85rem;
  color: #888;
  margin-top: 4px;
}

/* Underline the numeric count in the Writing page hero subtitle */
.page-writing .hero-count {
  text-decoration: underline;
  text-decoration-thickness: 2px;
  text-underline-offset: 0.12em;
  text-decoration-color: currentColor;
}

/* ─── Research DOI / volume meta ─────────────────────────────────────────────
   Extra metadata line shown on research cards.
*/
.card-doi {
  font-size: 0.75rem;
  color: #999;
  margin-top: 4px;
  word-break: break-all;
}

/* ─── Booking CTA block ──────────────────────────────────────────────────────
   Callout block on the speaking page inviting visitors to book.
*/
.booking-cta {
  background: #f7f7f7;
  border: 1px solid #e5e5e5;
  border-radius: 12px;
  padding: 32px 40px;
  margin: 48px 40px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}

.booking-cta-text h2 {
  font-size: 1.3rem;
  font-weight: 700;
  margin: 0 0 6px;
}

.booking-cta-text p {
  font-size: 0.95rem;
  color: #555;
  margin: 0;
}

.booking-cta-btn {
  display: inline-block;
  background: #111;
  color: #fff;
  padding: 12px 28px;
  border-radius: 6px;
  font-size: 0.95rem;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
  transition:
    background 0.2s ease,
    transform 0.15s ease;
}

.booking-cta-btn:hover {
  background: #333;
  transform: translateY(-1px);
}

@media screen and (max-width: 700px) {
  .booking-cta {
    padding: 24px 20px;
    margin: 32px 16px 0;
    flex-direction: column;
    align-items: flex-start;
  }
}

/* ─── Homepage hero bio sentence ─────────────────────────────────────────────*/
.home-hero-bio {
  font-size: 0.9rem;
  color: #666;
  margin: 6px 0 0;
  max-width: 420px;
  line-height: 1.5;
}

/* ─── "See all writing" link row ─────────────────────────────────────────────*/
.see-all-row {
  display: flex;
  justify-content: flex-end;
  padding: 8px 0 24px;
}

.see-all-link {
  font-size: 0.9rem;
  font-weight: 600;
  color: #111;
  text-decoration: none;
  border-bottom: 1px solid #111;
  padding-bottom: 1px;
  transition: opacity 0.15s ease;
}

.see-all-link:hover {
  opacity: 0.6;
}

/* ─── "AS SEEN IN" eyebrow label above logos carousel ───────────────────────*/
.logos-eyebrow {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #aaa;
  text-align: center;
  margin: 0 0 12px;
}

/* ------------------------------------------------------------
   2026 UI polish pass: visual consistency + cleaner hierarchy
   ------------------------------------------------------------ */
:root {
  --ui-radius-sm: 8px;
  --ui-radius-md: 14px;
  --ui-radius-lg: 20px;
  --ui-surface: #ffffff;
  --ui-muted-surface: #f7f8fa;
  --ui-border: rgba(15, 23, 36, 0.1);
  --ui-border-strong: rgba(45, 37, 100, 0.28);
  --ui-shadow-soft: 0 12px 30px rgba(15, 23, 36, 0.06);
  --ui-shadow-card: 0 10px 24px rgba(15, 23, 36, 0.08);
}

body {
  background: #ffffff;
  color: #101010;
}

.header-container {
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-bottom: 1px solid rgba(15, 23, 36, 0.08);
  padding-left: clamp(14px, 2vw, 24px);
  padding-right: clamp(14px, 2vw, 24px);
}

.page-hero-title {
  background: linear-gradient(180deg, #ffffff 0%, #fbfbfc 100%);
  border-bottom: 1px solid rgba(15, 23, 36, 0.06);
  padding-top: 18px;
  padding-bottom: 14px;
}

.page-subtitle {
  line-height: 1.6;
  max-width: 68ch;
}

.home-hero-subtitle,
.home-hero-bio {
  max-width: 68ch;
}

.filters-row {
  background: rgba(255, 255, 255, 0.88);
  border: 1px solid var(--ui-border);
  border-radius: var(--ui-radius-md);
  box-shadow: var(--ui-shadow-soft);
  padding: 14px;
}

.filter-col {
  margin-bottom: 0;
}

.filter-col input,
.filter-col select {
  border: 1px solid rgba(45, 37, 100, 0.18);
  border-radius: 10px;
  background: #fff;
  transition:
    border-color 0.2s ease,
    box-shadow 0.2s ease,
    background-color 0.2s ease;
}

.filter-col input:hover,
.filter-col select:hover {
  border-color: rgba(45, 37, 100, 0.35);
}

.filter-col input:focus,
.filter-col select:focus {
  border-color: var(--ui-border-strong);
  box-shadow: 0 0 0 3px rgba(45, 37, 100, 0.12);
  background: #fff;
}

#articleList {
  padding-bottom: 36px;
}

.bento-grid {
  gap: 20px;
}

.bento-card {
  border-radius: var(--ui-radius-md);
  border: 1px solid rgba(15, 23, 36, 0.08);
  background: var(--ui-surface);
  box-shadow: var(--ui-shadow-card);
  overflow: hidden;
  transition:
    transform 0.22s ease,
    box-shadow 0.22s ease,
    border-color 0.22s ease;
}

.bento-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 34px rgba(15, 23, 36, 0.14);
  border-color: rgba(45, 37, 100, 0.25);
}

.card-media,
.article-img,
.text-cover {
  border-radius: 0;
}

.bento-card .card-media,
.bento-card .text-cover {
  transition: transform 0.3s ease;
}

.bento-card:hover .card-media,
.bento-card:hover .text-cover {
  transform: scale(1.03);
}

.card-body {
  padding: 16px 16px 18px;
}

.card-title {
  line-height: 1.34;
}

.card-meta,
.card-date,
.card-authors {
  line-height: 1.45;
}

.site-footer {
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.site-footer .footer-nav a {
  border-radius: 999px;
  transition:
    background-color 0.2s ease,
    color 0.2s ease;
}

.site-footer .footer-nav a:hover {
  background: rgba(255, 255, 255, 0.1);
}

@media (prefers-reduced-motion: no-preference) {
  .page-hero-title,
  .home-hero,
  .filters-row,
  .bento-card {
    animation: ui-fade-up 320ms ease-out both;
  }

  .bento-card:nth-child(2n) {
    animation-delay: 45ms;
  }

  .bento-card:nth-child(3n) {
    animation-delay: 90ms;
  }
}

@keyframes ui-fade-up {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media screen and (max-width: 700px) {
  .header-container {
    padding-left: 10px;
    padding-right: 10px;
  }

  .page-hero-title {
    padding-top: 14px;
    padding-bottom: 10px;
  }

  .filters-row {
    border-radius: 12px;
    padding: 10px;
    gap: 10px;
  }

  .bento-grid {
    gap: 14px;
  }

  .bento-card {
    border-radius: 12px;
  }
}

/* ------------------------------------------------------------
   2026 second pass: spacing, format, colors
   ------------------------------------------------------------ */
:root {
  --section-space-desktop: 84px;
  --section-space-mobile: 48px;
  --copy-color: #303742;
  --muted-copy-color: #5d6673;
  --accent-indigo: #221a4f;
  --platform-accent: #0f3ba6;
}

.page-hero-title {
  padding-top: 22px;
  padding-bottom: 18px;
}

.page-hero-inner h1 {
  margin-bottom: 10px;
  letter-spacing: 0.6px;
}

.page-subtitle {
  color: var(--muted-copy-color);
  font-size: 15px;
  line-height: 1.65;
}

.page-subtitle .page-contact {
  color: var(--accent-indigo);
}

.filters-row {
  margin-top: 10px;
  margin-bottom: 14px;
  padding: 12px;
  row-gap: 10px;
}

.filter-col input,
.filter-col select {
  min-height: 42px;
  font-size: 14px;
  color: #1d2430;
}

.filter-col input::placeholder {
  color: #737c88;
}

#articleList {
  padding-top: 6px;
  padding-bottom: var(--section-space-desktop);
}

.bento-card {
  border-color: rgba(15, 23, 36, 0.1);
}

.card-body {
  padding: 18px 18px 20px;
}

.card-journal,
.article-journal {
  color: var(--accent-indigo);
  font-size: 14px;
  letter-spacing: 0.35px;
}

.card-meta,
.card-date,
.card-authors,
.article-meta {
  color: var(--copy-color);
  opacity: 0.92;
}

.card-meta-block {
  gap: 4px;
}

.site-footer {
  margin-top: var(--section-space-desktop);
}

@media screen and (max-width: 1000px) {
  .page-hero-title {
    padding-top: 18px;
    padding-bottom: 14px;
  }

  .filters-row {
    margin-bottom: 10px;
  }

  #articleList {
    padding-bottom: 64px;
  }
}

@media screen and (max-width: 700px) {
  .page-hero-inner h1 {
    margin-bottom: 8px;
  }

  .page-subtitle {
    font-size: 14px;
    line-height: 1.55;
  }

  .filters-row {
    margin-top: 6px;
    margin-bottom: 8px;
    padding: 8px;
  }

  .filter-col input,
  .filter-col select {
    min-height: 40px;
    font-size: 14px;
  }

  .card-body {
    padding: 14px 14px 16px;
  }

  .card-title {
    margin-bottom: 6px;
    line-height: 1.3;
  }

  #articleList {
    padding-bottom: var(--section-space-mobile);
  }

  .site-footer {
    margin-top: var(--section-space-mobile);
  }
}

/* ------------------------------------------------------------
   2026 refinement pass: cleaner editorial look
   ------------------------------------------------------------ */
.page-writing .page-hero-inner h1,
.page-research .page-hero-inner h1,
.page-media .page-hero-inner h1,
.page-speaker .page-hero-inner h1,
.page-creative .page-hero-inner h1,
.page-about .page-hero-inner h1 {
  text-wrap: balance;
}

.page-writing .page-subtitle,
.page-research .page-subtitle,
.page-media .page-subtitle,
.page-speaker .page-subtitle,
.page-creative .page-subtitle,
.page-about .page-subtitle {
  max-width: 62ch;
}

/* Research page: stronger hierarchy and cleaner card rhythm */
.page-research .page-hero-title {
  border-bottom: 1px solid rgba(45, 37, 100, 0.12);
}

.page-research .page-hero-inner h1 {
  font-weight: 650;
  letter-spacing: 0.4px;
}

.page-research .page-subtitle {
  color: #4e5866;
}

.page-research .filters-row {
  border-color: rgba(45, 37, 100, 0.22);
  box-shadow: 0 8px 24px rgba(15, 23, 36, 0.06);
}

.page-research #articleList {
  padding-top: 10px;
}

.page-research .bento-grid {
  gap: 22px;
}

.page-research .bento-card {
  border: 1px solid rgba(45, 37, 100, 0.16);
  box-shadow: 0 12px 28px rgba(15, 23, 36, 0.08);
}

.page-research .bento-card:hover {
  border-color: rgba(45, 37, 100, 0.3);
  box-shadow: 0 18px 36px rgba(15, 23, 36, 0.14);
}

.page-research .card-media {
  height: 220px;
  object-position: center top;
}

.page-research .card-body {
  padding: 18px 18px 20px;
}

.page-research .card-title {
  font-size: 1.08rem;
  line-height: 1.36;
}

.page-research .card-journal {
  color: #1f2f7a;
  font-size: 0.86rem;
  font-weight: 800;
  letter-spacing: 0.4px;
  margin-bottom: 4px;
}

.page-research .card-meta-block {
  border-top: 1px solid rgba(15, 23, 36, 0.08);
  margin-top: 12px;
  padding-top: 10px;
  gap: 2px;
}

.page-research .card-date {
  color: #263147;
}

.page-research .card-authors {
  color: #535f70;
}

@media screen and (max-width: 1000px) {
  .page-research .card-media {
    height: 190px;
  }

  .page-research .bento-grid {
    gap: 16px;
  }
}

@media screen and (max-width: 700px) {
  .page-research .filters-row {
    border-color: rgba(45, 37, 100, 0.18);
    box-shadow: none;
  }

  .page-research .card-media {
    height: 168px;
  }

  .page-research .card-body {
    padding: 14px 14px 16px;
  }

  .page-research .card-title {
    font-size: 1rem;
  }
}

/* ------------------------------------------------------------
   2026 minimal/professional pass
   ------------------------------------------------------------ */
:root {
  --pro-border: rgba(15, 23, 36, 0.12);
  --pro-text: #18202c;
  --pro-muted: #5d6673;
}

/* Calmer, flatter header treatment */
.header-container {
  background: #ffffff;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border-bottom: 1px solid rgba(15, 23, 36, 0.09);
}

.nav {
  gap: 10px;
}

/* Navigation: minimal professional look */
.nav-item {
  border-radius: 6px;
}

.nav-item a {
  padding: 7px 11px;
  border-radius: 6px;
  font-size: 0.84rem;
  letter-spacing: 0.08em;
  transition:
    color 0.14s ease,
    background-color 0.14s ease;
}

.nav-item:hover {
  background: rgba(45, 37, 100, 0.05);
}

.nav-item:hover a,
.nav-item:has(a:focus-visible) a,
.nav-item:active a {
  color: #111;
}

/* Remove decorative gradients and keep section surfaces clean */
.page-hero-title {
  background: #ffffff;
}

.page-subtitle {
  color: var(--pro-muted);
  letter-spacing: 0.2px;
}

/* Filters: less glassy, more precise */
.filters-row {
  background: #ffffff;
  border: 1px solid var(--pro-border);
  box-shadow: none;
  border-radius: 10px;
  padding: 10px;
}

.filter-col input,
.filter-col select {
  border: 1px solid var(--pro-border);
  box-shadow: none;
}

.filter-col input:focus,
.filter-col select:focus {
  border-color: rgba(45, 37, 100, 0.35);
  box-shadow: 0 0 0 2px rgba(45, 37, 100, 0.1);
}

/* Cards: restrained elevation and typography polish */
.bento-card {
  border: 1px solid rgba(15, 23, 36, 0.1);
  box-shadow: 0 3px 10px rgba(15, 23, 36, 0.06);
  border-radius: 10px;
}

.bento-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 18px rgba(15, 23, 36, 0.1);
  border-color: rgba(15, 23, 36, 0.16);
}

.bento-card:hover .card-media,
.bento-card:hover .text-cover {
  transform: none;
}

.card-journal,
.article-journal {
  font-size: 0.84rem;
  font-weight: 700;
  letter-spacing: 0.25px;
}

.card-date,
.card-authors,
.card-meta,
.article-meta {
  color: var(--pro-muted);
  opacity: 1;
}

/* Footer links: cleaner interaction */
.site-footer .footer-nav a {
  border-radius: 4px;
}

.site-footer .footer-nav a:hover {
  background: transparent;
  color: #ffd700;
}

/* Keep motion subtle for a professional tone */
@media (prefers-reduced-motion: no-preference) {
  .page-hero-title,
  .home-hero,
  .filters-row,
  .bento-card {
    animation-duration: 180ms;
  }
}

@media screen and (max-width: 700px) {
  .filters-row {
    border-radius: 8px;
    padding: 8px;
  }

  .card-title {
    font-size: 1rem;
  }
}

/* ------------------------------------------------------------
   2026 cleanup pass: simplify and harmonize
   ------------------------------------------------------------ */
/* Keep one visual system across pages (remove heavy page-specific styling) */
.page-research .page-hero-title {
  border-bottom: 1px solid rgba(15, 23, 36, 0.09);
}

.page-research .filters-row {
  border-color: var(--pro-border);
  box-shadow: none;
}

.page-research .bento-grid {
  gap: 20px;
}

.page-research .bento-card {
  border: 1px solid rgba(15, 23, 36, 0.1);
  box-shadow: 0 3px 10px rgba(15, 23, 36, 0.06);
}

.page-research .bento-card:hover {
  border-color: rgba(15, 23, 36, 0.16);
  box-shadow: 0 8px 18px rgba(15, 23, 36, 0.1);
}

.page-research .card-media {
  height: 210px;
  object-position: center center;
}

.page-research .card-title {
  font-size: 1.03rem;
}

.page-research .card-journal {
  color: var(--accent-indigo);
  font-size: 0.84rem;
  font-weight: 700;
  letter-spacing: 0.25px;
}

.page-research .card-meta-block {
  border-top: 0;
  margin-top: 0;
  padding-top: 0;
  gap: 4px;
}

.page-research .card-date {
  color: #2d2564;
  font-weight: 700;
  letter-spacing: 0.2px;
}

.page-research .card-authors {
  color: var(--pro-muted);
}

/* Remove staged entrance animation for a cleaner, quieter feel */
@media (prefers-reduced-motion: no-preference) {
  .page-hero-title,
  .home-hero,
  .filters-row,
  .bento-card {
    animation: none;
  }
}

@media screen and (max-width: 1000px) {
  .page-research .bento-grid {
    gap: 18px;
  }
}

/* Restore stronger platform/outlet emphasis on card pages. */
.page-writing .card-journal,
.page-research .card-journal,
.page-media .card-journal,
.page-creative .card-journal,
.page-speaker .card-journal {
  color: var(--platform-accent);
  font-size: 0.9rem;
  font-weight: 800;
  letter-spacing: 0.35px;
  line-height: 1.3;
}

@media screen and (max-width: 700px) {
  .page-writing .card-journal,
  .page-research .card-journal,
  .page-media .card-journal,
  .page-creative .card-journal,
  .page-speaker .card-journal {
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.3px;
  }
}

/* Speaker cards: move platform/course lower and closer to the date block. */
.page-speaker .card-content {
  display: flex;
  flex-direction: column;
  flex: 1 1 auto;
}

.page-speaker .card-journal {
  margin-top: auto;
  margin-bottom: 6px;
}

.page-speaker .card-course {
  margin-bottom: 4px;
}

.page-speaker .card-course::after,
.page-speaker .card-content:not(:has(.card-course)) .card-journal::after {
  content: none;
  display: none;
}

.page-speaker .card-body {
  gap: 8px;
}

@media screen and (max-width: 700px) {
  .page-research .card-media {
    height: 160px;
  }
}

/* ------------------------------------------------------------
   Footer gap trim for article index pages
   ------------------------------------------------------------ */
.page-writing #articleList,
.page-research #articleList,
.page-creative #articleList,
.page-media #articleList,
.page-speaker #articleList {
  padding-bottom: 28px;
}

.page-writing .site-footer,
.page-research .site-footer,
.page-creative .site-footer,
.page-media .site-footer,
.page-speaker .site-footer {
  margin-top: 24px;
}

@media screen and (max-width: 700px) {
  .page-writing #articleList,
  .page-research #articleList,
  .page-creative #articleList,
  .page-media #articleList,
  .page-speaker #articleList {
    padding-bottom: 16px;
  }

  .page-writing .site-footer,
  .page-research .site-footer,
  .page-creative .site-footer,
  .page-media .site-footer,
  .page-speaker .site-footer {
    margin-top: 16px;
  }
}

/* ------------------------------------------------------------
   Header system pass: clean, professional, and consistent
   ------------------------------------------------------------ */
.page-writing .page-hero-title,
.page-research .page-hero-title,
.page-creative .page-hero-title,
.page-media .page-hero-title,
.page-speaker .page-hero-title,
.page-about .page-hero-title {
  background: #fcfdff;
  border: 1px solid rgba(15, 23, 36, 0.08);
  border-left: none;
  border-right: none;
  padding-top: 36px;
  padding-bottom: 26px;
}

.page-writing .page-hero-inner,
.page-research .page-hero-inner,
.page-creative .page-hero-inner,
.page-media .page-hero-inner,
.page-speaker .page-hero-inner,
.page-about .page-hero-inner {
  width: 75%;
  margin-left: 11%;
}

.page-writing .page-hero-inner h1,
.page-research .page-hero-inner h1,
.page-creative .page-hero-inner h1,
.page-media .page-hero-inner h1,
.page-speaker .page-hero-inner h1,
.page-about .page-hero-inner h1 {
  margin: 0 0 12px 0;
  font-size: clamp(34px, 4.1vw, 52px);
  font-weight: 680;
  line-height: 1.1;
  letter-spacing: 0.02px;
  color: #0f1724;
  text-wrap: balance;
  transform: translateX(-0.6px);
}

/* Form page styles (Book a Talk) - minimal, polished */
.form-page .page-hero-title {
  padding-bottom: 26px;
}
.contact-section .container {
  max-width: 900px;
  margin: 38px auto 56px auto;
  display: flex;
  gap: 48px;
  align-items: flex-start;
  padding: 0 0;
  box-sizing: border-box;
}
.contact-form-wrap {
  flex: 1.7 1 0%;
  min-width: 340px;
  max-width: 540px;
  margin-right: 0;
}
.contact-form-wrap .fs-success,
.contact-form-wrap .fs-error {
  margin-bottom: 14px;
}
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
  background: var(--ui-surface);
  padding: 32px 32px 28px 32px;
  border-radius: 16px;
  border: 1px solid var(--ui-border);
  box-shadow: 0 8px 32px rgba(15, 23, 36, 0.1);
}
.contact-copy {
  flex: 1 1 0%;
  min-width: 180px;
  max-width: 260px;
  margin-left: 0;
  margin-top: 18px;
  color: #444;
}
.contact-copy h2 {
  margin-top: 0;
  font-size: 1.13rem;
  margin-bottom: 10px;
}
.contact-copy p {
  font-size: 1rem;
  line-height: 1.7;
}
.contact-form label {
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--pro-text);
}
.contact-form input,
.contact-form textarea {
  padding: 12px 14px;
  border: 1px solid rgba(15, 23, 36, 0.06);
  border-radius: 8px;
  font-size: 1rem;
  background: #fff;
  color: var(--pro-text);
  transition:
    box-shadow 0.12s ease,
    border-color 0.12s ease;
  width: 100%;
  box-sizing: border-box;
}
.contact-form input,
.contact-form textarea,
.contact-form select,
.contact-form button {
  font-family:
    Roboto,
    system-ui,
    -apple-system,
    "Segoe UI",
    "Helvetica Neue",
    Arial,
    sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
.contact-form input[type="date"],
.contact-form input[type="datetime-local"],
.contact-form input[type="time"] {
  font-family:
    Roboto,
    system-ui,
    -apple-system,
    "Segoe UI",
    "Helvetica Neue",
    Arial,
    sans-serif;
}
.contact-form textarea {
  min-height: 140px;
  resize: vertical;
}
.contact-form input:focus,
.contact-form textarea:focus {
  outline: none;
  border-color: rgba(45, 37, 100, 0.22);
  box-shadow: 0 6px 18px rgba(15, 23, 36, 0.06);
}
.form-btn {
  background: #111;
  color: #fff;
  padding: 12px 18px;
  border-radius: 10px;
  border: 0;
  font-weight: 700;
  cursor: pointer;
  letter-spacing: 0.02em;
  align-self: flex-start;
}
.form-btn:disabled {
  opacity: 0.6;
  cursor: default;
}
.fs-success,
.fs-error {
  padding: 12px;
  border-radius: 8px;
  margin-bottom: 12px;
  font-weight: 600;
}
.fs-success {
  background: #e6ffef;
  border: 1px solid #b6f0c9;
  color: #0b6b2c;
}
.fs-error {
  background: #fff3f3;
  border: 1px solid #f0b6b6;
  color: #7a1414;
}
.field-error {
  color: #7a1414;
  font-size: 0.92rem;
  display: block;
  margin-top: 4px;
}

/* Small helper / accessibility tweaks */
.contact-form label + input,
.contact-form label + textarea {
  margin-top: 6px;
}
.contact-form input[required],
.contact-form textarea[required] {
  box-shadow: none;
}

@media (max-width: 900px) {
  .contact-section .container {
    gap: 20px;
    margin: 18px auto 36px auto;
    max-width: 98vw;
  }
  .contact-copy {
    order: 2;
    max-width: 100%;
    margin-top: 18px;
  }
  .contact-form-wrap {
    order: 1;
    max-width: 100%;
  }
  .contact-form {
    padding: 18px 10px;
    border-radius: 12px;
  }
}

@media (max-width: 700px) {
  .contact-section .container {
    flex-direction: column;
    width: calc(100% - 32px);
    margin: 0 16px 28px;
    max-width: 100vw;
  }
  .contact-form-wrap,
  .contact-copy {
    width: 100% !important;
    min-width: auto;
    max-width: 100%;
  }
  .contact-form input,
  .contact-form textarea {
    font-size: 0.95rem;
  }
  .form-btn {
    width: 100%;
    text-align: center;
  }
  .contact-form {
    padding: 14px 4px;
    border-radius: 10px;
  }
}

.page-writing .page-subtitle,
.page-research .page-subtitle,
.page-creative .page-subtitle,
.page-media .page-subtitle,
.page-speaker .page-subtitle,
.page-about .page-subtitle {
  margin: 0;
  max-width: 56ch;
  color: #4f5968;
  font-size: 15px;
  font-weight: 450;
  line-height: 1.62;
  letter-spacing: 0.15px;
}

/* Small page-specific accents for distinction without noise. */
.page-writing .page-hero-title {
  border-bottom-color: rgba(45, 37, 100, 0.2);
}

.page-research .page-hero-title {
  border-bottom-color: rgba(36, 66, 94, 0.2);
}

.page-creative .page-hero-title {
  border-bottom-color: rgba(108, 87, 52, 0.2);
}

.page-media .page-hero-title {
  border-bottom-color: rgba(146, 110, 17, 0.25);
}

.page-speaker .page-hero-title {
  border-bottom-color: rgba(45, 37, 100, 0.24);
}

.page-writing .page-subtitle .page-contact,
.page-research .page-subtitle .page-contact,
.page-creative .page-subtitle .page-contact,
.page-media .page-subtitle .page-contact,
.page-speaker .page-subtitle .page-contact {
  border-bottom: 1px solid rgba(45, 37, 100, 0.24);
}

@media (prefers-reduced-motion: no-preference) {
  .page-writing .page-hero-inner,
  .page-research .page-hero-inner,
  .page-creative .page-hero-inner,
  .page-media .page-hero-inner,
  .page-speaker .page-hero-inner,
  .page-about .page-hero-inner {
    animation: heroReveal 260ms ease-out both;
  }

  @keyframes heroReveal {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
}

@media screen and (max-width: 700px) {
  .page-writing .page-hero-title,
  .page-research .page-hero-title,
  .page-creative .page-hero-title,
  .page-media .page-hero-title,
  .page-speaker .page-hero-title,
  .page-about .page-hero-title {
    padding-top: 24px;
    padding-bottom: 20px;
    border-top-color: rgba(15, 23, 36, 0.07);
  }

  .page-writing .page-hero-inner,
  .page-research .page-hero-inner,
  .page-creative .page-hero-inner,
  .page-media .page-hero-inner,
  .page-speaker .page-hero-inner,
  .page-about .page-hero-inner {
    width: calc(100% - 32px);
    margin: 0 16px;
  }

  .page-writing .page-hero-inner h1,
  .page-research .page-hero-inner h1,
  .page-creative .page-hero-inner h1,
  .page-media .page-hero-inner h1,
  .page-speaker .page-hero-inner h1,
  .page-about .page-hero-inner h1 {
    font-size: clamp(30px, 9.2vw, 40px);
    margin-bottom: 10px;
    transform: translateX(-0.4px);
  }

  .page-writing .page-subtitle,
  .page-research .page-subtitle,
  .page-creative .page-subtitle,
  .page-media .page-subtitle,
  .page-speaker .page-subtitle,
  .page-about .page-subtitle {
    font-size: 14px;
    font-weight: 450;
    line-height: 1.58;
    max-width: 100%;
  }
}

/* ------------------------------------------------------------
   Unified Bento System (global final override)
   ------------------------------------------------------------ */
:root {
  --bento-gap-desktop: 20px;
  --bento-gap-tablet: 16px;
  --bento-gap-mobile: 14px;
  --bento-radius: 12px;
  --bento-border: rgba(15, 23, 36, 0.1);
  --bento-border-hover: rgba(15, 23, 36, 0.2);
  --bento-shadow: 0 6px 18px rgba(15, 23, 36, 0.08);
  --bento-shadow-hover: 0 14px 30px rgba(15, 23, 36, 0.14);
  --bento-body-pad-y: 16px;
  --bento-body-pad-x: 16px;
}

.bento-grid {
  gap: var(--bento-gap-desktop);
  align-items: stretch;
}

.bento-card {
  border-radius: var(--bento-radius);
  border: 1px solid var(--bento-border);
  box-shadow: var(--bento-shadow);
  overflow: hidden;
  height: 100%;
  transition:
    transform 0.22s ease,
    box-shadow 0.22s ease,
    border-color 0.2s ease;
}

.bento-card:hover {
  transform: translateY(-3px);
  border-color: var(--bento-border-hover);
  box-shadow: var(--bento-shadow-hover);
}

.bento-card a.card-link {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.card-media,
.text-cover {
  width: 100%;
  display: block;
  flex-shrink: 0;
}

/* Keep cover-text lecture cards centered in the speaker page media area. */
.page-speaker .text-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.card-body {
  padding: var(--bento-body-pad-y) var(--bento-body-pad-x);
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1 1 auto;
}

.card-content {
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1 1 auto;
}

.card-title {
  margin: 0;
  line-height: 1.32;
  font-size: 1.03rem;
  font-weight: 700;
}

.card-journal,
.article-journal {
  color: var(--platform-accent);
  line-height: 1.3;
  margin: 0;
}

.card-course {
  line-height: 1.28;
  margin: 0;
}

.card-meta-block {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.card-date,
.card-authors,
.card-meta,
.article-meta {
  margin: 0;
  line-height: 1.4;
}

.card-tags-inline {
  gap: 8px;
}

@media screen and (max-width: 1000px) {
  .bento-grid {
    gap: var(--bento-gap-tablet);
  }

  .card-body {
    padding: 15px 14px;
    gap: 7px;
  }
}

@media screen and (max-width: 700px) {
  .bento-grid {
    gap: var(--bento-gap-mobile);
  }

  .card-body {
    padding: 14px 14px 16px;
    gap: 7px;
  }

  .card-title {
    font-size: 1rem;
    line-height: 1.3;
  }

  .card-meta-block {
    gap: 5px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .bento-card,
  .bento-card:hover {
    transition: none;
    transform: none;
  }
}

/* ------------------------------------------------------------
   Filter UX final polish: clean, modern, single-system controls
   ------------------------------------------------------------ */
.filters-row.has-chip-ui {
  display: grid;
  grid-template-columns: minmax(0, 1.5fr) minmax(220px, 1fr);
  align-items: center;
  gap: 10px;
  padding: 10px;
  border: 1px solid rgba(15, 23, 36, 0.13);
  border-radius: 10px;
  background: #fff;
  box-shadow: none;
}

.filters-row.has-chip-ui .filter-col {
  width: auto;
  margin: 0;
  padding: 0;
}

.filters-row.has-chip-ui .filter-col input,
.filters-row.has-chip-ui .filter-col select {
  min-height: 42px;
  border-radius: 8px;
  border: 1px solid rgba(15, 23, 36, 0.14);
  background: #fff;
  color: #18202c;
  font-size: 14px;
  letter-spacing: 0.01em;

  /* Tighten spacing between the Formspree success/error banner and the form
   on the form page: small consistent gap so the banner sits visually attached
   to the form without large margins. */
  .form-page .contact-form-wrap .fs-success,
  .form-page .contact-form-wrap .fs-error,
  .form-page .fs-success,
  .form-page .fs-error {
    margin-bottom: 8px;
    border-radius: 10px 10px 0 0; /* align top corners with the form card */
    padding: 10px 12px;
  }
  .form-page .contact-form {
    margin-top: 0; /* ensure form sits directly under the banner */
    border-radius: 0 0 16px 16px; /* keep form bottom radius only */
  }

  /* Remove shadows on the form and success/error banner for form pages
   so they appear cleanly connected without a floating shadow between them. */
  .form-page .contact-form,
  .form-page .contact-form-wrap .fs-success,
  .form-page .contact-form-wrap .fs-error,
  .form-page .fs-success,
  .form-page .fs-error {
    box-shadow: none !important;
  }

  /* When the Formspree success banner becomes visible, show it as a
   detached banner and hide the form beneath it so the thank-you is
   clearly separated from the form card. */
  .form-page .fs-success:not([hidden]) {
    /* Show the success banner as a detached, fixed overlay so it does
     not create layout gaps where the form sits. Keep the form
     visible beneath it. */
    display: block;
    margin: 0;
    padding: 12px 16px;
    border-radius: 10px;
    background: #e6ffef;
    border: 1px solid #b6f0c9;
    color: #0b6b2c;
    box-shadow: 0 6px 18px rgba(15, 23, 36, 0.06);
    position: fixed;
    top: 84px; /* adjust to sit below header if needed */
    left: 50%;
    transform: translateX(-50%);
    width: min(920px, calc(100% - 32px));
    z-index: 9999;
  }

  /* Keep the form visible; banner is an overlay */
  .form-page .fs-success:not([hidden]) ~ .contact-form {
    display: block;
  }

  /* Visual close affordance (pure CSS) */
  .form-page .fs-success:not([hidden])::after {
    content: "×";
    position: absolute;
    right: 12px;
    top: 8px;
    font-size: 18px;
    line-height: 1;
    color: inherit;
  }

  /* Additional fixes to remove unexpected gaps between the thank-you
   banner and the form: remove top margin/padding on the banner and
   remove form margins. Scope to `.form-page` to avoid global side-effects. */
  .form-page .fs-success,
  .form-page .fs-error {
    margin-top: 0 !important;
    padding-top: 0 !important;
    margin-bottom: 8px !important; /* small gap if form remains visible */
  }
  .form-page .contact-form {
    margin: 0 !important;
  }

  /* If any invisible elements (e.g., stray paragraphs) are inserted by
   editors between the banner and the form, collapse their space. */
  .form-page .contact-form-wrap p,
  .form-page .contact-form-wrap br {
    margin: 0 !important;
    padding: 0 !important;
    line-height: 0 !important;
  }
  transition:
    border-color 0.18s ease,
    box-shadow 0.18s ease,
    background-color 0.18s ease;
}

.filters-row.has-chip-ui .filter-col input::placeholder {
  color: #6c7684;
}

.filters-row.has-chip-ui .filter-col input:hover,
.filters-row.has-chip-ui .filter-col select:hover {
  border-color: rgba(34, 26, 79, 0.34);
}

.filters-row.has-chip-ui .filter-col input:focus,
.filters-row.has-chip-ui .filter-col select:focus {
  border-color: rgba(34, 26, 79, 0.44);
  box-shadow: 0 0 0 2px rgba(34, 26, 79, 0.14);
  background: #fff;
}

.filters-row.has-chip-ui .filter-col.tag-filter-col {
  display: none;
}

.filter-chip-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 7px;
  width: 75%;
  margin: 4px 11% 14px;
}

.filter-chip {
  padding: 6px 11px;
  border-radius: 999px;
  border: 1px solid rgba(34, 26, 79, 0.24);
  background: #fff;
  color: #221a4f;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  transition:
    background-color 0.18s ease,
    border-color 0.18s ease,
    color 0.18s ease,
    transform 0.18s ease;
}

.filter-chip:hover,
.filter-chip:focus-visible {
  border-color: rgba(34, 26, 79, 0.54);
  background: rgba(34, 26, 79, 0.08);
  transform: translateY(-1px);
  outline: none;
}

.filter-chip.is-active {
  background: #221a4f;
  border-color: #221a4f;
  color: #fff;
}

@media screen and (max-width: 700px) {
  .filters-row.has-chip-ui {
    grid-template-columns: 1fr;
    gap: 8px;
    padding: 8px;
    border-radius: 8px;
  }

  .filter-chip-row {
    width: calc(100% - 32px);
    margin: 4px 16px 10px;
    gap: 6px;
  }

  .filter-chip {
    padding: 6px 10px;
    font-size: 10px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .filters-row.has-chip-ui .filter-col input,
  .filters-row.has-chip-ui .filter-col select,
  .filter-chip,
  .filter-chip:hover {
    transition: none;
    transform: none;
  }

  .logos-scroll,
  .home-page .logos-scroll,
  .page-speaker .logos-scroll {
    animation: none !important;
    transform: none !important;
  }

  .nav-item,
  .portfolio-btn,
  .bento-card,
  .site-footer .footer-nav a {
    transition: none !important;
  }

  .nav-item:hover,
  .portfolio-btn:hover,
  .bento-card:hover {
    transform: none !important;
  }
}

@media screen and (max-width: 700px) {
  .page-writing .filters-row.has-chip-ui,
  .page-speaker .filters-row.has-chip-ui {
    width: calc(100% - 32px);
    margin: 8px 16px 6px;
    padding: 8px;
    gap: 7px;
    border-radius: 10px;
  }

  .page-writing .filters-row.has-chip-ui .filter-col input,
  .page-writing .filters-row.has-chip-ui .filter-col select,
  .page-speaker .filters-row.has-chip-ui .filter-col input,
  .page-speaker .filters-row.has-chip-ui .filter-col select {
    min-height: 40px;
    padding-top: 8px;
    padding-bottom: 8px;
  }

  .page-writing .filter-chip-row,
  .page-speaker .filter-chip-row {
    width: calc(100% - 32px);
    margin: 0 16px 10px;
    gap: 7px;
  }

  .page-writing .filter-chip,
  .page-speaker .filter-chip {
    padding: 6px 10px;
    font-size: 11px;
    letter-spacing: 0.2px;
  }
}

@media screen and (max-width: 700px) {
  .page-writing .page-hero-inner,
  .page-research .page-hero-inner,
  .page-creative .page-hero-inner,
  .page-media .page-hero-inner,
  .page-speaker .page-hero-inner,
  .page-about .page-hero-inner,
  .page-writing .filters-row.has-chip-ui,
  .page-research .filters-row.has-chip-ui,
  .page-creative .filters-row.has-chip-ui,
  .page-media .filters-row.has-chip-ui,
  .page-speaker .filters-row.has-chip-ui,
  .page-writing #articleList,
  .page-research #articleList,
  .page-creative #articleList,
  .page-media #articleList,
  .page-speaker #articleList {
    width: calc(100% - 32px);
    margin-left: 16px;
    margin-right: 16px;
    box-sizing: border-box;
  }

  .page-writing .filters-row.has-chip-ui,
  .page-research .filters-row.has-chip-ui,
  .page-creative .filters-row.has-chip-ui,
  .page-media .filters-row.has-chip-ui,
  .page-speaker .filters-row.has-chip-ui {
    margin-top: 8px;
    margin-bottom: 6px;
    padding: 8px;
    border-radius: 10px;
  }

  .page-writing .filter-chip-row,
  .page-research .filter-chip-row,
  .page-creative .filter-chip-row,
  .page-media .filter-chip-row,
  .page-speaker .filter-chip-row {
    width: calc(100% - 32px);
    margin: 0 16px 8px;
    display: flex;
    flex-wrap: nowrap;
    gap: 8px;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    box-sizing: border-box;
    padding: 0 2px 2px;
    scroll-padding-left: 2px;
    scroll-padding-right: 2px;
  }

  .page-writing .filter-chip-row::-webkit-scrollbar,
  .page-research .filter-chip-row::-webkit-scrollbar,
  .page-creative .filter-chip-row::-webkit-scrollbar,
  .page-media .filter-chip-row::-webkit-scrollbar,
  .page-speaker .filter-chip-row::-webkit-scrollbar {
    display: none;
  }

  .page-writing .filter-chip,
  .page-research .filter-chip,
  .page-creative .filter-chip,
  .page-media .filter-chip,
  .page-speaker .filter-chip {
    flex: 0 0 auto;
    white-space: nowrap;
    font-size: 10.5px;
    letter-spacing: 0.15px;
    padding: 6px 10px;
  }

  .page-writing .bento-grid,
  .page-research .bento-grid,
  .page-creative .bento-grid,
  .page-media .bento-grid,
  .page-speaker .bento-grid {
    margin-top: 4px;
    gap: 12px;
  }
}

@media screen and (max-width: 700px) {
  .page-container > .home-container {
    padding-top: 4px;
  }

  .page-writing .page-hero-title,
  .page-research .page-hero-title,
  .page-creative .page-hero-title,
  .page-media .page-hero-title,
  .page-speaker .page-hero-title,
  .page-about .page-hero-title {
    padding-bottom: 14px;
  }

  .page-writing .filters-row.has-chip-ui,
  .page-research .filters-row.has-chip-ui,
  .page-creative .filters-row.has-chip-ui,
  .page-media .filters-row.has-chip-ui,
  .page-speaker .filters-row.has-chip-ui {
    margin-top: 10px;
    margin-bottom: 8px;
  }

  .page-writing .filter-chip-row,
  .page-research .filter-chip-row,
  .page-creative .filter-chip-row,
  .page-media .filter-chip-row,
  .page-speaker .filter-chip-row {
    margin-bottom: 12px;
  }

  .page-writing #articleList,
  .page-research #articleList,
  .page-creative #articleList,
  .page-media #articleList,
  .page-speaker #articleList {
    padding-top: 0;
    padding-bottom: 12px;
  }

  .home-page .home-hero {
    margin-top: 8px;
    margin-bottom: 10px;
  }

  .home-page .featured-heading-section {
    padding-top: 10px;
  }

  .home-page .featured-works-container {
    margin-top: 4px;
    margin-bottom: 14px;
  }

  .site-footer {
    margin-top: 16px;
  }
}

@media screen and (max-width: 700px) {
  .home-page .home-hero .hero-cta-row {
    width: auto;
    margin-top: 12px;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .home-page .home-hero .hero-cta-row .portfolio-btn {
    min-height: 38px;
    padding: 0.35rem 0.75rem;
    font-size: 0.9rem;
    line-height: 1.2;
    white-space: nowrap;
  }

  .home-page .home-hero .hero-cta-row .portfolio-btn.speaking {
    min-width: 0;
  }

  .home-page .home-hero .hero-cta-row .portfolio-btn.cv {
    min-width: 0;
    padding: 0.35rem 0.62rem;
  }

  .home-page .home-hero .hero-cta-row .portfolio-btn svg {
    margin-right: 0.28em;
  }
}

/* Footer text clipping fix: keep rights text fully visible */
.site-footer .footer-right {
  min-width: 0;
}

.site-footer .footer-right p {
  max-width: 100%;
  overflow-wrap: anywhere;
}

@media (max-width: 1024px) {
  .mobile-footer-rights {
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
    line-height: 1.35;
    letter-spacing: 0.4px;
    padding: 10px 14px;
  }
}

/* ------------------------------------------------------------
   2026 clean visual pass: consistency + readability
   ------------------------------------------------------------ */
:root {
  --surface-base: #ffffff;
  --surface-soft: #f7f7f5;
  --text-primary: #101418;
  --text-muted: #4c5561;
  --stroke-soft: rgba(16, 24, 36, 0.12);
  --elevation-soft: 0 8px 24px rgba(16, 24, 36, 0.08);
  --elevation-hover: 0 16px 34px rgba(16, 24, 36, 0.12);
}

html {
  scroll-behavior: smooth;
}

body {
  background: linear-gradient(180deg, #ffffff 0%, #fafaf8 42%, #ffffff 100%);
  color: var(--text-primary);
  text-rendering: optimizeLegibility;
}

.header-container {
  border-bottom: 1px solid var(--stroke-soft);
  background: #ffffff;
}

.nav-item a {
  letter-spacing: 0.6px;
  border-bottom: 2px solid transparent;
  transition:
    color 0.2s ease,
    border-color 0.2s ease;
}

.nav-item a[aria-current="page"],
.nav-item a.is-active {
  border-bottom-color: #ffd700;
}

.nav-item:hover a,
.nav-item:has(a:focus-visible) a {
  color: #111;
}

.home-hero-subtitle,
.page-subtitle {
  max-width: 68ch;
  color: var(--text-muted);
  line-height: 1.66;
}

.featured-heading,
.logos-section h3,
.spoken-section h3 {
  letter-spacing: 1.5px;
}

.filters-row {
  background: var(--surface-soft);
  border: 1px solid rgba(16, 24, 36, 0.08);
  border-radius: 12px;
  padding: 12px;
}

.filter-col {
  margin-bottom: 0;
}

.filter-col input,
.filter-col select {
  min-height: 44px;
  border-color: rgba(16, 24, 36, 0.16);
  border-radius: 10px;
}

.bento-grid {
  gap: 22px;
}

.bento-card {
  border: 1px solid rgba(16, 24, 36, 0.08);
  border-radius: 14px;
  box-shadow: var(--elevation-soft);
  background: var(--surface-base);
}

.bento-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--elevation-hover);
}

.card-body {
  padding: 16px 17px 18px;
}

.card-title {
  line-height: 1.32;
}

.card-meta,
.card-meta-block,
.article-meta,
.article-journal {
  color: var(--text-muted);
}

.site-footer {
  border-top: 1px solid var(--stroke-soft);
  background: #fff;
}

.site-footer .footer-nav a {
  color: #18202c;
}

.site-footer .footer-nav a:hover,
.site-footer .footer-nav a:focus-visible {
  color: #000;
}

@media (prefers-reduced-motion: no-preference) {
  .header-container,
  .filters-row,
  .bento-card,
  .site-footer .footer-nav a,
  .nav-item a {
    transition:
      background-color 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease,
      color 0.25s ease;
  }

  .home-hero,
  .page-hero-title,
  .bento-card {
    animation: soft-rise 360ms ease-out both;
  }
}

@keyframes soft-rise {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media screen and (max-width: 700px) {
  .header-container {
    border-bottom-color: rgba(16, 24, 36, 0.1);
  }

  .filters-row,
  .page-writing .filters-row.has-chip-ui,
  .page-research .filters-row.has-chip-ui,
  .page-creative .filters-row.has-chip-ui,
  .page-media .filters-row.has-chip-ui,
  .page-speaker .filters-row.has-chip-ui {
    border-radius: 10px;
    padding: 8px;
  }

  .bento-grid {
    gap: 12px;
  }

  .bento-card {
    border-radius: 12px;
  }

  .home-hero-subtitle,
  .page-subtitle {
    line-height: 1.58;
  }
}

/* Footer rights typography polish: clean, minimal hierarchy */
.site-footer .footer-right p {
  font-size: 0.94rem;
  font-weight: 400;
  letter-spacing: 0.03em;
  color: #7a838f;
  line-height: 1.45;
}

.site-footer .footer-right .footer-name {
  color: inherit;
  font-weight: inherit;
  letter-spacing: inherit;
}

@media (max-width: 1024px) {
  .mobile-footer-rights {
    background: #fff;
    border-top: 1px solid var(--stroke-soft);
    font-size: clamp(0.78rem, 1.7vw, 0.9rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: #7a838f;
    line-height: 1.45;
  }

  .mobile-footer-rights .footer-name {
    color: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
  }
}

/* Keep homepage hero on the same page surface tone */
.home-page .home-hero {
  background: #fff;
}

.home-page .home-container,
.home-page .list-container {
  background: #fff;
}

/* Subtle motion pass: reduce movement and timing intensity */
@media (prefers-reduced-motion: no-preference) {
  .home-hero,
  .page-hero-title,
  .filters-row,
  .bento-card {
    animation-duration: 220ms !important;
    animation-timing-function: ease-out !important;
  }

  .bento-card:nth-child(2n) {
    animation-delay: 25ms !important;
  }

  .bento-card:nth-child(3n) {
    animation-delay: 45ms !important;
  }
}

.bento-card:hover {
  transform: translateY(-2px);
}

.bento-card:hover .card-media,
.bento-card:hover .text-cover {
  transform: scale(1.015);
}

@keyframes soft-rise {
  from {
    opacity: 0;
    transform: translateY(5px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes ui-fade-up {
  from {
    opacity: 0;
    transform: translateY(5px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Motion system polish: clean + minimal */
:root {
  --motion-duration-fast: 140ms;
  --motion-duration-base: 180ms;
  --motion-duration-reveal: 200ms;
  --motion-ease-standard: cubic-bezier(0.22, 0.61, 0.36, 1);
}

@media (prefers-reduced-motion: no-preference) {
  .nav-item,
  .nav-item a,
  .portfolio-btn,
  .bento-card,
  .bento-card .card-media,
  .bento-card .text-cover,
  .site-footer .footer-nav a,
  .filter-chip,
  .header-container,
  .filters-row {
    transition-duration: var(--motion-duration-base) !important;
    transition-timing-function: var(--motion-ease-standard) !important;
  }

  .home-hero,
  .page-hero-title,
  .filters-row,
  .bento-card {
    animation-duration: var(--motion-duration-reveal) !important;
    animation-timing-function: var(--motion-ease-standard) !important;
  }

  .bento-card:nth-child(2n),
  .bento-card:nth-child(3n) {
    animation-delay: 0ms !important;
  }
}

.nav-item:hover,
.portfolio-btn:hover,
.bento-card:hover {
  transform: translateY(-1px);
}

.bento-card:hover .card-media,
.bento-card:hover .text-cover {
  transform: scale(1.01);
}

@keyframes soft-rise {
  from {
    opacity: 0;
    transform: translateY(3px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes ui-fade-up {
  from {
    opacity: 0;
    transform: translateY(3px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ------------------------------------------------------------
   Background consistency pass: optimized across all pages
   ------------------------------------------------------------ */
:root {
  --bg-page: #ffffff;
  --bg-page-soft: #fafaf8;
  --bg-panel: #f7f7f5;
}

body {
  background: var(--bg-page);
  color: var(--text-primary, #101418);
}

body.home-page {
  background: linear-gradient(
    180deg,
    var(--bg-page) 0%,
    var(--bg-page-soft) 42%,
    var(--bg-page) 100%
  );
}

body.page-writing,
body.page-research,
body.page-creative,
body.page-media,
body.page-speaker,
body.page-vitae {
  background: var(--bg-page);
}

/* Mobile refinements for form pages (Bookings) */
@media screen and (max-width: 700px) {
  /* ensure the hero on form pages has the same breathing room as other pages */
  .form-page .page-hero-title {
    padding-top: 36px;
    padding-bottom: 20px; /* match other pages on mobile to avoid enlarged header */
    border-top: 1px solid rgba(15, 23, 36, 0.07);
  }

  .form-page .page-hero-inner {
    width: calc(100% - 40px);
    margin: 0 20px;
  }

  /* make the contact container sit nicely inside mobile gutters */
  .form-page .contact-section .container {
    flex-direction: column;
    width: calc(100% - 40px);
    margin: 20px 20px 40px; /* move form down slightly on mobile */
    gap: 22px;
    max-width: 100vw;
  }

  .form-page .contact-form-wrap,
  .form-page .contact-copy {
    width: 100% !important;
    max-width: 100%;
    min-width: auto;
    margin: 0;
  }

  .form-page .contact-form {
    padding: 20px 16px;
    border-radius: 14px;
  }

  .form-page .contact-form label {
    font-size: 0.82rem; /* keep uppercase labels readable but compact on mobile */
    margin-bottom: 6px;
  }

  .form-page .contact-form input,
  .form-page .contact-form textarea {
    padding: 13px 12px;
    font-size: 1rem;
  }

  .form-page .copy-card {
    padding: 18px 14px;
    border-radius: 12px;
    margin-top: 0;
  }

  .form-page .page-subtitle {
    margin-bottom: 0; /* align with other pages */
    font-size: 15px;
    line-height: 1.62;
    color: #4f5968;
    max-width: 56ch;
  }

  /* Remove extra white space above the right-side copy card */
  .form-page .contact-copy {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  /* Stack inline form rows and ensure inputs take full width on mobile */
  .form-page .form-row-inline {
    flex-direction: column;
    gap: 12px;
  }

  .form-page .form-row-inline .form-row,
  .form-page .form-row {
    width: 100%;
  }

  .form-page .form-row input,
  .form-page .form-row textarea,
  .form-page .form-row select {
    width: 100%;
    box-sizing: border-box;
  }

  /* Button goes full-width on mobile */
  .form-page .form-btn {
    width: 100%;
    padding: 15px 0;
  }

  /* Tighten section padding on small screens */
  .form-page .contact-section {
    padding-top: 24px;
    padding-bottom: 56px;
  }
}

/* Ensure form inputs/show white background on form pages (override) */
.form-page .contact-form input,
.form-page .contact-form textarea,
.form-page .contact-form select,
.form-page .contact-form input[type="date"],
.form-page .contact-form input[type="number"] {
  background-color: #f8f8fb !important;
  background-image: none !important;
  color: #232946;
  border: 1.5px solid #e2e2ea !important;
  border-radius: 8px;
}
.form-page .contact-form input:focus,
.form-page .contact-form textarea:focus {
  background-color: #fff !important;
  border-color: #0f1724 !important;
  box-shadow: none !important;
  outline: none;
}

.page-hero-title,
.home-page .home-hero,
.home-page .home-container,
.home-page .list-container {
  background: var(--bg-page);
}

.filters-row {
  background: var(--bg-panel);
}

/* ------------------------------------------------------------
   Homepage reimagined layout
   ------------------------------------------------------------ */
.home-page .home-container,
.home-page .list-container {
  background: transparent;
}

.home-page .home-canvas {
  width: min(1120px, calc(100% - 40px));
  margin: 30px auto 32px;
  display: grid;
  gap: 34px;
}

.home-page .site-footer {
  margin-top: 24px;
}

.home-page .home-intro {
  display: grid;
  grid-template-columns: 1.05fr 0.95fr;
  gap: 26px;
  align-items: stretch;
}

.home-page .home-intro-copy {
  padding: 40px 36px 36px;
  border-radius: 20px;
  border: 1px solid rgba(16, 24, 36, 0.1);
  background: #fafaf7;
  box-shadow: 0 4px 16px rgba(16, 24, 36, 0.07);
}

.home-page .home-kicker {
  margin: 0 0 10px;
  font-size: 0.76rem;
  font-weight: 800;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #414b58;
}

.home-page .home-title {
  margin: 0;
  font-size: clamp(2rem, 3.6vw, 3.15rem);
  line-height: 1.13;
  letter-spacing: -0.02em;
  color: #0f1724;
  text-wrap: balance;
}

.home-page .home-lede {
  margin: 18px 0 12px;
  max-width: 50ch;
  font-size: 1.06rem;
  line-height: 1.48;
  color: #455061;
}

.home-page .home-cta-row {
  margin-top: 24px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.home-page .home-cta-row .portfolio-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.38em;
  min-height: 36px;
  min-width: 0;
  padding: 0.34rem 0.86rem;
  font-size: 0.86rem;
  font-weight: 700;
  letter-spacing: 0.03em;
  line-height: 1.2;
  border-radius: 10px;
  white-space: nowrap;
}

.home-page .home-cta-row .portfolio-btn.speaking {
  background: transparent;
  border: none;
  color: #0f1724;
  padding: 0;
  min-height: auto;
  font-size: 0.92rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  box-shadow: none;
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
  text-decoration-color: rgba(15, 23, 36, 0.35);
}

.home-page .home-cta-row .portfolio-btn.speaking:hover,
.home-page .home-cta-row .portfolio-btn.speaking:focus-visible {
  transform: none;
  box-shadow: none;
  text-decoration-color: #0f1724;
}

.home-page .home-intro-portrait {
  margin: 0;
  min-height: 320px;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(16, 24, 36, 0.12);
  box-shadow: 0 18px 42px rgba(16, 24, 36, 0.1);
  background: #f3f5f8;
}

.home-page .home-intro-portrait img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.home-page .home-lanes {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.home-page .home-lane {
  text-decoration: none;
  color: inherit;
  padding: 20px 18px;
  border-radius: 14px;
  border: 1px solid rgba(16, 24, 36, 0.1);
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  transition:
    transform 0.18s ease,
    box-shadow 0.18s ease,
    border-color 0.18s ease;
}

.home-page .home-lane h2 {
  margin: 0;
  font-size: 1.08rem;
  letter-spacing: 0.03em;
  color: #111923;
}

.home-page .home-lane p {
  margin: 8px 0 0;
  font-size: 0.94rem;
  line-height: 1.55;
  color: #4f5a68;
}

.home-page .home-lane-cta {
  margin-top: auto;
  padding-top: 12px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #2d2564;
  align-self: flex-end;
}

.home-page .home-lane-arrow {
  display: inline-block;
  transition: transform 0.18s ease;
}

.home-page .home-lane:hover,
.home-page .home-lane:focus-visible {
  transform: translateY(-2px);
  border-color: rgba(45, 37, 100, 0.24);
  box-shadow: 0 12px 30px rgba(16, 24, 36, 0.08);
  outline: none;
}

.home-page .home-lane:hover .home-lane-arrow,
.home-page .home-lane:focus-visible .home-lane-arrow {
  transform: translateX(2px);
}

.home-page .home-latest-shell {
  padding: 24px 14px 28px;
  border-radius: 18px;
  border: 1px solid rgba(16, 24, 36, 0.1);
  background: #ffffff;
}

.home-page .home-latest-head {
  margin-bottom: 14px;
}

.home-page .home-latest-kicker {
  margin: 0;
  font-size: 0.74rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: #5d6673;
}

.home-page .home-latest-head h2 {
  margin: 8px 0 0;
  font-size: clamp(1.2rem, 2.2vw, 1.7rem);
  line-height: 1.24;
  color: #101821;
}

.home-page .home-canvas .home-latest-shell #homeFeaturedList {
  width: 100%;
  max-width: none;
  margin: 0 !important;
  padding: 0 !important;
}

.home-page .home-canvas .home-latest-shell #homeFeaturedList .bento-grid {
  gap: 22px;
}

.home-page .home-latest-shell .bento-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.home-page .home-latest-shell .bento-card {
  border-radius: 14px;
  border: 1px solid rgba(16, 24, 36, 0.08);
  background: var(--surface-base, #ffffff);
  box-shadow: var(--elevation-soft, 0 8px 24px rgba(16, 24, 36, 0.08));
  overflow: hidden;
  min-height: 100%;
}

.home-page .home-latest-shell .bento-card a.card-link {
  height: 100%;
}

.home-page .home-latest-shell .bento-card .card-media {
  height: 180px;
  min-height: 0;
  max-height: none;
  object-fit: cover;
}

.home-page .home-latest-shell .bento-card .card-body {
  padding: 16px 17px 18px;
}

.home-page .home-latest-shell .bento-card .card-content {
  gap: 8px;
}

.home-page .home-latest-shell .bento-card .card-title {
  font-size: 18px;
  line-height: 1.32;
  margin-bottom: 6px;
  -webkit-line-clamp: 3;
  line-clamp: 3;
}

.home-page .home-latest-shell .bento-card .card-journal {
  font-size: 14px;
  letter-spacing: 0.35px;
  text-transform: none;
  color: var(--accent-indigo, #221a4f);
  margin: 0 0 8px;
}

.home-page .home-latest-shell .bento-card .card-meta-block {
  margin-top: auto;
  padding-top: 0;
  border-top: none;
}

.home-page .home-latest-shell .bento-card .card-date {
  font-size: 13px;
  letter-spacing: 0;
  color: var(--text-muted, #4c5561);
}

.home-page .home-latest-shell .bento-card:hover,
.home-page .home-latest-shell .bento-card:focus-within {
  transform: translateY(-4px);
  box-shadow: var(--elevation-hover, 0 16px 34px rgba(16, 24, 36, 0.12));
  border-color: rgba(16, 24, 36, 0.08);
}

.home-page .home-latest-shell .bento-card:hover .card-media,
.home-page .home-latest-shell .bento-card:focus-within .card-media {
  transform: scale(1.015);
}

@media (max-width: 980px) {
  .home-page .home-intro {
    grid-template-columns: 1fr;
  }

  .home-page .home-intro-portrait {
    order: -1;
    min-height: 260px;
  }

  .home-page .home-intro-copy {
    order: 2;
  }

  .home-page .home-lanes {
    grid-template-columns: 1fr;
  }

  .home-page .home-latest-shell .bento-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .home-page .home-latest-shell .bento-card .card-media {
    height: 170px;
  }
}

@media (max-width: 700px) {
  .home-page .home-canvas {
    width: calc(100% - 32px);
    margin: 14px 16px 30px;
    gap: 16px;
  }

  .home-page .home-kicker {
    margin: 0 0 10px;
    font-size: 0.69rem;
    letter-spacing: 0.12em;
    line-height: 1.25;
  }

  .home-page .home-intro-copy {
    padding: 20px 18px;
    border-radius: 14px;
  }

  .home-page .home-lede {
    font-size: 0.98rem;
  }

  .home-page .home-cta-row {
    gap: 8px;
  }

  .home-page .home-cta-row .portfolio-btn {
    min-height: 36px;
    padding: 0.34rem 0.76rem;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }

  .home-page .home-intro-portrait {
    min-height: 230px;
  }

  .home-page .home-lane {
    padding: 15px 14px;
    border-radius: 12px;
  }

  .home-page .home-latest-shell {
    padding: 16px 12px 18px;
    border-radius: 12px;
  }

  .home-page .home-latest-shell .bento-grid {
    grid-template-columns: 1fr;
  }

  .home-page .home-latest-shell .bento-card .card-media {
    height: 150px;
  }

  .home-page .home-latest-shell .bento-card .card-title {
    font-size: 16px;
  }
}

@media (max-width: 520px) {
  .home-page .home-kicker {
    font-size: 0.66rem;
    letter-spacing: 0.1em;
  }

  .home-page .home-cta-row {
    width: 100%;
    flex-direction: row;
    align-items: center;
  }

  .home-page .home-cta-row .portfolio-btn {
    width: auto;
  }
}

/* All inner-page heroes: uppercase, tighter tracking, consistent size */
.page-writing .page-hero-inner h1,
.page-research .page-hero-inner h1,
.page-creative .page-hero-inner h1,
.page-media .page-hero-inner h1,
.page-speaker .page-hero-inner h1,
.page-about .page-hero-inner h1 {
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-size: clamp(22px, 3.6vw, 42px);
}

@media (max-width: 700px) {
  .page-writing .page-hero-inner h1,
  .page-research .page-hero-inner h1,
  .page-creative .page-hero-inner h1,
  .page-media .page-hero-inner h1,
  .page-speaker .page-hero-inner h1,
  .page-about .page-hero-inner h1 {
    font-size: clamp(26px, 8vw, 36px);
  }
}

/* Kicker: tighten letter-spacing slightly for better visual balance with h1 */
.hero-kicker {
  letter-spacing: 0.12em;
}

/* Hero count — indigo to match kicker, creates a visual thread */
.hero-count {
  color: #2d2564;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* ══════════════════════════════════════════════════════════════════════════
   Hero refresh — breathing room, kickers, entrance animation
   ══════════════════════════════════════════════════════════════════════════ */

@keyframes hero-fade-up {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Generous vertical space — the main fix */
.page-hero-title {
  padding-top: 64px;
  padding-bottom: 48px;
}

/* Subtle entrance */
@media (prefers-reduced-motion: no-preference) {
  .page-hero-inner {
    animation: hero-fade-up 0.38s ease-out both;
  }
}

/* Kicker — small label above the h1 */
.hero-kicker {
  display: block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #2d2564;
  opacity: 0.72;
  margin-bottom: 12px;
}

/* Stat chip — subtle social-proof inline element */
.hero-stat {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 600;
  color: #4e5866;
  letter-spacing: 0.02em;
  margin-top: 18px;
  padding: 4px 11px;
  border: 1px solid rgba(15, 23, 36, 0.1);
  border-radius: 20px;
  background: #f6f6f9;
}

/* CTA row inside the hero (Speaking / Bookings) */
.hero-page-cta-row {
  margin-top: 22px;
  display: flex;
  gap: 12px;
  align-items: center;
  flex-wrap: wrap;
}

/* Responsive scale-downs */
@media (max-width: 1000px) {
  .page-hero-title {
    padding-top: 48px;
    padding-bottom: 36px;
  }
}

@media (max-width: 700px) {
  .page-hero-title {
    padding-top: 36px;
    padding-bottom: 26px;
  }
  .hero-kicker {
    font-size: 0.65rem;
    margin-bottom: 8px;
  }
  .hero-page-cta-row {
    margin-top: 16px;
  }
}

/* ============================================================
   About page
   ============================================================ */

/* Hero accent colour unique to the About page */
.page-about .page-hero-title {
  border-bottom-color: rgba(34, 85, 55, 0.2);
}

/* Canvas */
.about-canvas {
  width: min(1120px, calc(100% - 40px));
  margin: 40px auto 60px;
  display: grid;
  gap: 28px;
}

/* Bio + photo */
.about-bio-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 26px;
  align-items: stretch;
}

.about-bio-text {
  padding: 40px 36px 36px;
  border-radius: 20px;
  border: 1px solid rgba(16, 24, 36, 0.1);
  background: #fafaf7;
  box-shadow: 0 4px 16px rgba(16, 24, 36, 0.07);
}


.about-bio-text p {
  margin: 0 0 14px;
  font-size: 1.02rem;
  line-height: 1.65;
  color: #384454;
}

.about-bio-text p:last-of-type {
  margin-bottom: 0;
}

.bio-link {
  color: inherit;
  font-weight: inherit;
  text-decoration: none;
  border-bottom: 1px solid rgba(16, 24, 36, 0.25);
  transition: border-bottom-color 0.15s ease;
}

.bio-link:hover {
  border-bottom-color: rgba(16, 24, 36, 0.6);
}

.about-bio-portrait {
  margin: 0;
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(16, 24, 36, 0.12);
  box-shadow: 0 18px 42px rgba(16, 24, 36, 0.1);
  background: #f3f5f8;
  min-height: 280px;
}

.about-bio-portrait img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: center top;
}

/* Credentials grid */
.about-credentials {
  padding: 32px 30px;
  border-radius: 18px;
  border: 1px solid rgba(16, 24, 36, 0.1);
  background: #ffffff;
}

.about-credentials > h2 {
  margin: 0 0 22px;
  padding-bottom: 14px;
  border-bottom: 1px solid rgba(16, 24, 36, 0.08);
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #1a2333;
}

.about-creds-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
}

.about-cred-card {
  padding: 18px 16px;
  border-radius: 12px;
  border: 1px solid rgba(16, 24, 36, 0.08);
  background: #fafaf7;
  transition:
    transform 0.18s ease,
    box-shadow 0.18s ease,
    border-color 0.18s ease;
}

.about-cred-card:hover {
  transform: translateY(-2px);
  border-color: rgba(45, 37, 100, 0.2);
  box-shadow: 0 8px 24px rgba(16, 24, 36, 0.08);
}

.about-cred-label {
  display: block;
  margin: 0 0 6px;
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #6b7685;
}

.about-cred-value {
  margin: 0;
  font-size: 0.95rem;
  line-height: 1.5;
  color: #1a2333;
  font-weight: 600;
}

.about-cred-sub {
  display: block;
  margin-top: 3px;
  font-size: 0.82rem;
  font-weight: 400;
  color: #596270;
  line-height: 1.45;
}

.about-cred-link {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
  text-decoration-thickness: 1px;
  text-decoration-color: rgba(15, 23, 36, 0.3);
}

.about-cred-link:hover {
  text-decoration-color: #0f1724;
}

/* CV CTA */
.about-cv-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding: 28px 30px;
  border-radius: 16px;
  border: 1px solid rgba(16, 24, 36, 0.1);
  background: #fafaf7;
}

.about-cv-text h3 {
  margin: 0 0 4px;
  font-size: 1.08rem;
  font-weight: 700;
  color: #0f1724;
}

.about-cv-text p {
  margin: 0;
  font-size: 0.9rem;
  color: #596270;
  line-height: 1.5;
}

.about-cv-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 0.6rem 1.4rem;
  border-radius: 10px;
  background: #0f1724;
  color: #ffffff;
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 0.03em;
  text-decoration: none;
  white-space: nowrap;
  transition:
    background 0.18s ease,
    transform 0.18s ease;
}

.about-cv-btn:hover,
.about-cv-btn:focus-visible {
  background: #2d2564;
  transform: translateY(-1px);
}

/* Responsive */
@media (max-width: 860px) {
  .about-bio-section {
    grid-template-columns: 1fr;
  }

  .about-bio-portrait {
    min-height: 280px;
    order: -1;
  }

  .about-creds-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀